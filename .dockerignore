# Version control
.git/
.gitignore
.gitattributes

# Secrets — never bake into the image
.env
.env.*
.env.local
.env.*.local

# Python bytecode and caches
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Virtual environments
.venv/
venv/
env/

# Test and coverage artefacts
.coverage
.coverage.*
htmlcov/
coverage.xml

# Build / dist artefacts
dist/
build/
*.egg-info/

# Local SQLite session memory (created at runtime, not needed in image)
**/.data/

# Editor and OS noise
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Docs / architecture (not needed at runtime)
docs/
architecture/

# Container config (build context is the project root, not container/)
# container/ is intentionally NOT excluded so the Dockerfile can be found.
