{
    "type": "record",
    "name": "workorder",
    "namespace": "com.canonicla.trendwell.vehivle",
    "fields": [
        {
            "name": "workOrderIdentifier",
            "type": "string",
            "doc": "Work Order unique record identifier generated by the system"
        },
        {
            "name": "workOrderNumber",
            "type": "string",
            "doc": "Internally-autogenerated number from Salesforce that identifies the work order"
        },
        {
            "name": "salesOrderIdentifier",
            "type": [
                "null",
                "string"
            ],
            "doc": "Unique Id of the Sales Order linked to the work order upon creation of a service appointment",
            "default": null
        },
        {
            "name": "appointmentIdentifier",
            "type": [
                "null",
                "string"
            ],
            "doc": "Unique Id of the Appointment associated to the work order",
            "default": null
        },
        {
            "name": "vehicleInspectionIdentifier",
            "type": [
                "null",
                "string"
            ],
            "doc": "Vehicle Inspection unique record identifier created by SAP",
            "default": null
        },
        {
            "name": "siteNumber",
            "type": "string",
            "doc": "Site Id of the site/store where work order is performed"
        },
        {
            "name": "storeCode",
            "type": [
                "null",
                "string"
            ],
            "doc": "Code representing the store where the work order is to be performed",
            "default": null
        },
        {
            "name": "customerIdentifier",
            "type": [
                "null",
                "string"
            ],
            "doc": "Customer Number Unique record Id generated by C360",
            "default": null
        },
        {
            "name": "customerVehicleIdentifier",
            "type": "string",
            "doc": "Customer Vehicle Id of the customer's unique vehicle (VIN) assigned to the work order"
        },
        {
            "name": "vehicleIdentifier",
            "type": [
                "null",
                "string"
            ],
            "doc": "Vehicle Id of the generic vehicle matching that of the customer vehicle assigned to the work order",
            "default": null
        },
        {
            "name": "trimIdentifier",
            "type": [
                "null",
                "string"
            ],
            "doc": "Unique identifier generated from SAP to denote the version of the customer's vehicle model",
            "default": null
        },
        {
            "name": "assemblyIdentifier",
            "type": [
                "null",
                "string"
            ],
            "doc": "Unique identifier generated from SAP denoting the vehicle's assembly type",
            "default": null
        },
        {
            "name": "vehicleMileage",
            "type": [
                "null",
                "string"
            ],
            "doc": "Number of miles driven by the vehicle taken from the odometer",
            "default": null
        },
        {
            "name": "createTimestamp",
            "type": "string",
            "doc": "Timestamp identifying the date and time the work order record was generated by the system"
        },
        {
            "name": "lastModifyTimestamp",
            "type": [
                "null",
                "string"
            ],
            "doc": "Timestamp identifying the date and time the work order record was last modified",
            "default": null
        },
        {
            "name": "workOrderStatus",
            "type": [
                "null",
                "string"
            ],
            "doc": "Code describing the current state of the work order",
            "default": null
        },
        {
            "name": "workOrderCheckInTimestamp",
            "type": [
                "null",
                "string"
            ],
            "doc": "Timestamp identifying the date and time the work order was checked into the service queue",
            "default": null
        },
        {
            "name": "latestAwaitingServiceTimestamp",
            "type": [
                "null",
                "string"
            ],
            "doc": "Timestamp identifying the time the vehicle was last awaiting service",
            "default": null
        },
        {
            "name": "bayInTimestamp",
            "type": [
                "null",
                "string"
            ],
            "doc": "Timestamp identifying the date and time the work order physically begins and vehicle is 'Bayed In'",
            "default": null
        },
        {
            "name": "bayOutTimestamp",
            "type": [
                "null",
                "string"
            ],
            "doc": "Timestamp identifying the date and time the work order is completed and vehicle is 'Bayed Out'",
            "default": null
        },
        {
            "name": "promiseTime",
            "type": [
                "null",
                "string"
            ],
            "doc": "Timestamp identifying the date and time which the work order is expected to be completed by",
            "default": null
        },
        {
            "name": "totalWaitTime",
            "type": [
                "null",
                "int"
            ],
            "doc": "Aggregation of time customer spent waiting for work order to be completed",
            "default": null
        },
        {
            "name": "totalBayTime",
            "type": [
                "null",
                "int"
            ],
            "doc": "Duration in minutes the customer's vehicle spent in 'In-Bay' status",
            "default": null
        },
        {
            "name": "paymentStatus",
            "type": [
                "null",
                "string"
            ],
            "doc": "Status denoting whether customer has paid in full for the articles and services associated to the work order",
            "default": null
        },
        {
            "name": "carryOutIndicator",
            "type": "boolean",
            "doc": "Flag indicating if work order is a carry out"
        },
        {
            "name": "returnForServiceIndicator",
            "type": [
                "null",
                "string"
            ],
            "doc": "Flag indicating if a work order will require an additional follow up to complete",
            "default": null
        },
        {
            "name": "orderTypeName",
            "type": [
                "null",
                "string"
            ],
            "doc": "Code identifying the type of work order",
            "default": null
        },
        {
            "name": "VIN",
            "type": [
                "null",
                "string"
            ],
            "doc": "Vehicle Identification Number",
            "default": null
        },
        {
            "name": "reservationIdentifier",
            "type": [
                "null",
                "string"
            ],
            "doc": "Reservation Id of the reservation record describing the date and time the work order is to be performed",
            "default": null
        },
        {
            "name": "walkInIndicator",
            "type": [
                "null",
                "string"
            ],
            "doc": "Flag indicating if customer linked to work order was a walk-in or reserved an appointment in advance",
            "default": null
        },
        {
            "name": "dropOffWaitIndicator",
            "type": [
                "null",
                "string"
            ],
            "doc": "Flag indicating if customer chose to drop off vehicle or is waiting in-store for work order to be completed",
            "default": null
        },
        {
            "name": "delayIndicator",
            "type": "boolean",
            "doc": "Flag indicating if work order is delayed",
            "default": false
        },
        {
            "name": "delayReasonShort",
            "type": [
                "null",
                "string"
            ],
            "doc": "Shortened description of full reason for service delay",
            "default": null
        },
        {
            "name": "timeOffset",
            "type": [
                "null",
                "string"
            ],
            "doc": "Time difference in hours between the local timestamp and the coordinated universal timestamp (UTC)",
            "default": null
        },
        {
            "name": "vehicleCategoryName",
            "type": [
                "null",
                "string"
            ],
            "doc": "Name of the generic vehicle category to which the vehicle belongs",
            "default": null
        },
        {
            "name": "vehicleSubcategoryName",
            "type": [
                "null",
                "string"
            ],
            "doc": "Name of the vehicle subcategory to which the vehicle belongs",
            "default": null
        },
        {
            "name": "totalUnitsQuantity",
            "type": "int",
            "doc": "Total units (tire & wheel) contained on the line items in this work order"
        },
        {
            "name": "workOrderType",
            "type": "string",
            "doc": "Type describes the predominant work being done. Units, Service or Other"
        },
        {
            "name": "delayReasonPrimary",
            "type": [
                "null",
                "string"
            ],
            "doc": "Primary reason for delay in servicing customer vehicle",
            "default": null
        },
        {
            "name": "delayReasonSecondary",
            "type": [
                "null",
                "string"
            ],
            "doc": "Seconday reason for delay in servicing customer vehicle",
            "default": null
        },
        {
            "name": "delayReasonTertiary",
            "type": [
                "null",
                "string"
            ],
            "doc": "Tertiary reaon for delay in servicing customer vehicle",
            "default": null
        },
        {
            "name": "lineItems",
            "type": {
                "type": "array",
                "items": {
                    "type": "record",
                    "name": "WorkOrderLineItem",
                    "fields": [
                        {
                            "name": "lineItemNumber",
                            "type": "string",
                            "doc": "Unique number generated by SAP identifying the article listed on the work order line item"
                        },
                        {
                            "name": "articleNumber",
                            "type": [
                                "null",
                                "string"
                            ],
                            "doc": "Unique number identifying the article listed on the work order line item",
                            "default": null
                        },
                        {
                            "name": "articleTypeCode",
                            "type": [
                                "null",
                                "string"
                            ],
                            "doc": "Code identifying the type of article listed on the work order line item",
                            "default": null
                        },
                        {
                            "name": "articleDescription",
                            "type": [
                                "null",
                                "string"
                            ],
                            "doc": "Description of the article type relevant to the work order line item",
                            "default": null
                        },
                        {
                            "name": "articleQuantity",
                            "type": [
                                "null",
                                "double"
                            ],
                            "doc": "Count of articles required to fulfill the work order line item",
                            "default": null
                        },
                        {
                            "name": "articleUnitPriceAmount",
                            "type": [
                                "null",
                                "double"
                            ],
                            "doc": "The unit price of the article, in dollars",
                            "default": null
                        },
                        {
                            "name": "articleUnitPriceDiscountAmount",
                            "type": [
                                "null",
                                "double"
                            ],
                            "doc": "The discounted unit price of the article, in dollars, for use in work order receipt",
                            "default": null
                        }
                    ]
                }
            },
            "doc": "WorkOrderLineItem is a collection of line item entries that specify the articles and/or services to be provided to the customer",
            "default": []
        },
        {
            "name": "bayAssignments",
            "type": {
                "type": "array",
                "items": {
                    "type": "record",
                    "name": "WorkOrderBayAssignment",
                    "fields": [
                        {
                            "name": "bayNumber",
                            "type": "string",
                            "doc": "Unique number of the DT bay within the store"
                        },
                        {
                            "name": "bayStartTimestamp",
                            "type": "string",
                            "doc": "Timestamp identifying the date and time the associated bay assignment begins relevant to the scheduled work order"
                        },
                        {
                            "name": "bayEndTimestamp",
                            "type": [
                                "null",
                                "string"
                            ],
                            "doc": "Timestamp identifying the date and time the bay assignment ends relevant to the scheduled work order",
                            "default": null
                        },
                        {
                            "name": "bayEndWorkOrderStatus",
                            "type": [
                                "null",
                                "string"
                            ],
                            "doc": "Description indicating the current state of a Bay Assignment within the store (e.g., Active, Inactive)",
                            "default": null
                        },
                        {
                            "name": "bayTotalTime",
                            "type": [
                                "null",
                                "int"
                            ],
                            "doc": "Total time the vehicle spent in the current bay assignment",
                            "default": null
                        }
                    ]
                }
            },
            "doc": "WorkOrderBayAssignment is a collection of bay assignemnts created each time the vehicle assigned to the work is 'bayed in'",
            "default": []
        },
        {
            "name": "employees",
            "type": {
                "type": "array",
                "items": {
                    "type": "record",
                    "name": "WorkOrderEmployee",
                    "fields": [
                        {
                            "name": "employeeIdentifier",
                            "type": "string",
                            "doc": "Employee Id of the personnel providing a service required on the work order"
                        }
                    ]
                }
            },
            "doc": "WorkOrderEmployee namespace is a construct isolating the identification for the employee that provides the service for the work order",
            "default": []
        },
        {
            "name": "contact",
            "type": {
                "type": "record",
                "name": "WorkOrderContact",
                "fields": [
                    {
                        "name": "contactFirstName",
                        "type": [
                            "null",
                            "string"
                        ],
                        "doc": "First name of the customer contact serving as a point of communication for a work order",
                        "default": null
                    },
                    {
                        "name": "contactLastName",
                        "type": [
                            "null",
                            "string"
                        ],
                        "doc": "Last name of the customer contact serving as a point of communication for a work order",
                        "default": null
                    },
                    {
                        "name": "contactEmail",
                        "type": [
                            "null",
                            "string"
                        ],
                        "doc": "Email address of the customer contact serving as a point of communication for a work order",
                        "default": null
                    },
                    {
                        "name": "contactPhone",
                        "type": [
                            "null",
                            "string"
                        ],
                        "doc": "Phone number of the customer contact serving as a point of communication for a work order",
                        "default": null
                    }
                ]
            },
            "doc": "WorkOrderContact namespace is a construct isolating the customer contact PII for the work order"
        }
    ]
}