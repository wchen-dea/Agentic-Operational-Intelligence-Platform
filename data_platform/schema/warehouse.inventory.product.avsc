{
  "type": "record",
  "name": "product",
  "namespace": "com.canonicla.warehouse.inventory",
  "fields": [
    {
      "name": "articleNumber",
      "type": "string",
      "doc": "Unique article number generated by the system"
    },
    {
      "name": "articleDescription",
      "type": "string",
      "doc": "Description of the article"
    },
    {
      "name": "articleTypeCode",
      "type": "string",
      "doc": "Code representing the type of article (tire, wheel, accessory, service, promotion, misc, etc.)"
    },
    {
      "name": "articleUPCNumber",
      "type": ["null", "string"],
      "doc": "Article's Universal Product Code",
      "default": null
    },
    {
      "name": "brandIdentifier",
      "type": ["null", "string"],
      "doc": "Unique identifier of the brand of the article",
      "default": null
    },
    {
      "name": "brandCategoryCode",
      "type": ["null", "string"],
      "doc": "Code representing the brand category",
      "default": null
    },
    {
      "name": "brandDescription",
      "type": ["null", "string"],
      "doc": "Description of the brand",
      "default": null
    },
    {
      "name": "familyIdentifier",
      "type": ["null", "string"],
      "doc": "Unique identifier of the family of products the article belongs to",
      "default": null
    },
    {
      "name": "familyDescription",
      "type": ["null", "string"],
      "doc": "Description of the family of products",
      "default": null
    },
    {
      "name": "lineIdentifier",
      "type": ["null", "string"],
      "doc": "Id identify the line of the article",
      "default": null
    },
    {
      "name": "lineDescription",
      "type": ["null", "string"],
      "doc": "Description of the line",
      "default": null
    },
    {
      "name": "vendorIdentifier",
      "type": ["null", "string"],
      "doc": "Unique identifier of the vendor of the article",
      "default": null
    },
    {
      "name": "merchandiseCategoryCode",
      "type": "string",
      "doc": "Code representing the merchandise category to which the article belongs"
    },
    {
      "name": "merchandiseCategoryDescription",
      "type": ["null", "string"],
      "doc": "Description of the merchandise category",
      "default": null
    },
    {
      "name": "merchandiseSegmentCode",
      "type": "string",
      "doc": "Code representing the merchandise segment to which the article belongs"
    },
    {
      "name": "merchandiseSegmentDescription",
      "type": ["null", "string"],
      "doc": "Description of the merchandise segment",
      "default": null
    },
    {
      "name": "externalMerchandiseCategoryCode",
      "type": ["null", "string"],
      "doc": "Code representing the external merchandise category of the article",
      "default": null
    },
    {
      "name": "storeArticleSizeDescription",
      "type": ["null", "string"],
      "doc": "Description of the size of an article",
      "default": null
    },
    {
      "name": "storeArticleDescription",
      "type": ["null", "string"],
      "doc": "Description of the article used across stores",
      "default": null
    },
    {
      "name": "coreMarketingIdentifier",
      "type": ["null", "string"],
      "doc": "Identifier that tells a store what products they should focus their marketing on",
      "default": null
    },
    {
      "name": "coreMarketingDescription",
      "type": ["null", "string"],
      "doc": "Description of code telling a store what products to focus marketing on (examples are core, non-core, etc.)",
      "default": null
    },
    {
      "name": "baseUnitOfMeasure",
      "type": ["null", "string"],
      "doc": "Unit of measure used to determine how much of an article is in one \"unit\"",
      "default": null
    },
    {
      "name": "createdDate",
      "type": "string",
      "doc": "Date article record was created"
    },
    {
      "name": "manufacturerCode",
      "type": ["null", "string"],
      "doc": "Code representing the manufacturer of the article",
      "default": null
    },
    {
      "name": "articleLifecycleStatusCode",
      "type": ["null", "string"],
      "doc": "Code representing an article's current position in its lifecycle (active, retired, discontinued, etc.)",
      "default": null
    },
    {
      "name": "articleLifecycleDescription",
      "type": ["null", "string"],
      "doc": "Description of the article's current position in its lifecycle",
      "default": null
    },
    {
      "name": "materialCode",
      "type": ["null", "string"],
      "doc": "Code representing the material that makes up the article",
      "default": null
    },
    {
      "name": "certificateSoldIndicator",
      "type": ["null", "string"],
      "doc": "Flag indicating if certificates can be applied toward article purchase",
      "default": null
    },
    {
      "name": "divisionCode",
      "type": ["null", "string"],
      "doc": "Code representing the division relevant to the article",
      "default": null
    },
    {
      "name": "industrySectorCode",
      "type": ["null", "string"],
      "doc": "Code representing the industry sector which the article belongs",
      "default": null
    },
    {
      "name": "volumeUnitQuantity",
      "type": ["null", "string"],
      "doc": "Volume of a single unit used to calculate the unit price",
      "default": null
    },
    {
      "name": "weightUnitQuantity",
      "type": ["null", "string"],
      "doc": "Weight of a single unit used to calculate the unit price",
      "default": null
    },
    {
      "name": "grossWeight",
      "type": ["null", "float"],
      "doc": "Gross weight of the article (including packaging material)",
      "default": null
    },
    {
      "name": "netWeight",
      "type": ["null", "float"],
      "doc": "Net weight of the article (not including packaging material)",
      "default": null
    },
    {
      "name": "articleDeletionFlag",
      "type": "boolean",
      "doc": "Material flag for deletion of article"
    },
    {
      "name": "articleDeletionDate",
      "type": ["null", "string"],
      "doc": "Date timestamp when article record was deleted at the client level",
      "default": null
    },
    {
      "name": "manufacturerDescription",
      "type": ["null", "string"],
      "doc": "Date timestamp when article record was deleted at the client level",
      "default": null
    },
    {
      "name": "tire",
      "type": [
        "null",
        {
          "type": "record",
          "name": "ArticleTire",
          "fields": [
            {
              "name": "speedRatingCode",
              "type": ["null", "string"],
              "doc": "Code representing the recommended safe speed range for a given tire",
              "default": null
            },
            {
              "name": "tireCrossSectionNumber",
              "type": "string",
              "doc": "Cross section number for a given tire"
            },
            {
              "name": "tireAspectRatio",
              "type": ["null", "string"],
              "doc": "Aspect ratio for a given tire",
              "default": null
            },
            {
              "name": "tireRimSizeNumber",
              "type": "string",
              "doc": "Rim size for a given tire"
            },
            {
              "name": "tireLoadRangeCode",
              "type": ["null", "string"],
              "doc": "Load range for a given tire",
              "default": null
            },
            {
              "name": "mileageGrpTreadwellCode",
              "type": ["null", "string"],
              "doc": "Code provided by Treadwell representing the milage group of a given tire",
              "default": null
            },
            {
              "name": "mileageGrpTreadwellDescription",
              "type": ["null", "string"],
              "doc": "Description of the mileage group a given tire belongs to as calculated by Treadwell",
              "default": null
            },
            {
              "name": "tireTestGrpTreadwellCode",
              "type": ["null", "string"],
              "doc": "Code provided by Treadwell representing the test group of a given tire",
              "default": null
            },
            {
              "name": "tireTestGrpTreadwellDescription",
              "type": ["null", "string"],
              "doc": "Description of the test group of a given tire as calculated by Treadwell",
              "default": null
            },
            {
              "name": "treadDepth",
			  "type": ["null", "string"],
              "doc": "Tread depth of a given tire"
            },
            {
              "name": "tireLoadCapacity",
              "type": ["null", "string"],
              "doc": "Load capacity of a given tire",
              "default": null
            },
            {
              "name": "tireLoadIndex",
              "type": ["null", "int"],
              "doc": "Load index of a given tire, which indicates how much weight a given tire can sustain",
              "default": null
            },
            {
              "name": "tireDiameter",
              "type": ["null", "float"],
              "doc": "Diameter of a given tire",
              "default": null
            },
            {
              "name": "tireConstructionCode",
              "type": ["null", "string"],
              "doc": "Code representing the construction of a given tire",
              "default": null
            },
            {
              "name": "tractionGradeCode",
              "type": ["null", "string"],
              "doc": "Code representing the traction grade of a given tire",
              "default": null
            },
            {
              "name": "treadwearGradeCode",
              "type": ["null", "string"],
              "doc": "Code representing treadwear grade assigned to a given tire as calculated by Treadwell",
              "default": null
            },
            {
              "name": "sideWallCode",
              "type": ["null", "string"],
              "doc": "Code representing the sidewall of a given tire (relates to tire specs and dimensions)",
              "default": null
            },
            {
              "name": "dtcMileageWarranty",
              "type": ["null", "string"],
              "doc": "The mileage a given tire can drive before the Discount Tire warrantly is nulled",
              "default": null
            },
            {
              "name": "manufacturerMileageWarranty",
              "type": ["null", "string"],
              "doc": "The mileage a given tire can drive before the manufacturer's warrantly is nulled",
              "default": null
            },
            {
              "name": "productRatingDescription",
              "type": ["null", "string"],
              "doc": "Description of a given tire's rating relative to similar tires determined by Treadwell (good, better, best)",
              "default": null
            },
            {
              "name": "discountTireMaxWidth",
              "type": ["null", "float"],
              "doc": "Discount Tire's reccomended maximum width for a given tire",
              "default": null
            },
            {
              "name": "discountTireMinWidth",
              "type": ["null", "float"],
              "doc": "Discount Tire's reccomended minimum width for a given tire",
              "default": null
            },
            {
              "name": "vendorMaxWidth",
              "type": ["null", "float"],
              "doc": "The vendor's reccomended maximum width for a given tire",
              "default": null
            },
            {
              "name": "vendorMinWidth",
              "type": ["null", "float"],
              "doc": "The vendor's reccomended minimum width for a given tire",
              "default": null
            },
            {
              "name": "tempGradeCode",
              "type": ["null", "string"],
              "doc": "Unique code to indicate the maximum temperature range of a given tire",
              "default": null
            },
            {
              "name": "primaryVNLoadIndex",
              "type": ["null", "string"],
              "doc": "VN Load index reading",
              "default": null
            },
            {
              "name": "treadDesignCode",
              "type": ["null", "string"],
              "doc": "Code representing the tread design of a given tire",
              "default": null
            },
            {
              "name": "maxAirPressureNumber",
              "type": ["null", "int"],
              "doc": "The maximum air pressure reccomended for a given tire",
              "default": null
            },
            {
              "name": "runFlatIndicator",
              "type": ["null", "string"],
              "doc": "Flag indicating that specific tire can be run without air for a set distance",
              "default": null
            }
          ]
        }
      ],
      "doc": "ArticleTire is an optional namespace that will be populated when the Article.articleTypeCode = 'ZTIR'",
      "default": null
    },
    {
      "name": "wheel",
      "type": [
