{
	"type": "record",
	"name": "detail",
	"namespace": "com.canonicla.sap.salesorder",
	"fields": [
		{
			"name": "salesOrderIdentifier",
			"type": "string",
			"doc": "Unique Sales Order record identifier generated by the system"
		},
		{
			"name": "originalSalesOrderIdentifier",
			"type": [
				"null",
				"string"
			],
			"doc": "Unique Original Sales Order record identifier generated by the system",
			"default": null
		},
		{
			"name": "siteNumber",
			"type": "string",
			"doc": "Site unique identifier where a sales order was created"
		},
		{
			"name": "profitCenterCode",
			"type": "string",
			"doc": "Profit Center Code unique identifier where a sales order was created"
		},
		{
			"name": "customerIdentifier",
			"type": "string",
			"doc": "Customer (C360) unique identifier for a customer who a sales order was created for"
		},
		{
			"name": "customerVehicleIdentifier",
			"type": [
				"null",
				"string"
			],
			"doc": "unique identifier for a customer's vehicle that is being worked on as part of a sales order",
			"default": null
		},
		{
			"name": "vehicleIdentifier",
			"type": [
				"null",
				"string"
			],
			"doc": "Vehicle Unique record Id identifying the brand, make, model, etc. For the customer's vehicle being worked on as part of the sales order",
			"default": null
		},
		{
			"name": "trimIdentifier",
			"type": [
				"null",
				"string"
			],
			"doc": "Vehicle Trim Id denoting the trim level of the vehicle assigned to the work order",
			"default": null
		},
		{
			"name": "assemblyIdentifier",
			"type": [
				"null",
				"string"
			],
			"doc": "Vehicle Assembly Id denoting the assembly of the vehicle assigned to the work order",
			"default": null
		},
		{
			"name": "liftIdentifier",
			"type": [
				"null",
				"string"
			],
			"doc": "Vehicle Lift Id",
			"default": null
		},
		{
			"name": "salesOrderCreatedDate",
			"type": "string",
			"doc": "The date the sales order record was generated by the system"
		},
		{
			"name": "salesOrderStatusCode",
			"type": "string",
			"doc": "Sales Order StatusCode (A,B,C)"
		},
		{
			"name": "salesOrderStatusDescription",
			"type": "string",
			"doc": "Sales Order Status Description"
		},
		{
			"name": "salesOrderDocumentTypeCode",
			"type": "string",
			"doc": "Code indicating the type of sales order document"
		},
		{
			"name": "salesOrderDocumentTypeDescription",
			"type": "string",
			"doc": "Description of the business function of the document being given to the customer as part of the sales order (Order, Return, etc.)"
		},
		{
			"name": "distributionChannel",
			"type": [
				"null",
				"string"
			],
			"doc": "Distribution Channel used on the current sales order",
			"default": null
		},
		{
			"name": "orderTransactionTypeCode",
			"type": "string",
			"doc": "Code representing the type of transaction that occured (01, 02, 03, 04, 05)"
		},
		{
			"name": "orderTransactionTypeDescription",
			"type": "string",
			"doc": "Description of the type of transaction that occured (01 - BOPIS, 02 - ROPIS, 03 - DTD, 04 - Serivce Appointment, 05 - Store Order)"
		},
		{
			"name": "lastModifyTimestamp",
			"type": [
				"null",
				"string"
			],
			"doc": "Timestamp identifying the date and time the sales order record was last modified",
			"default": null
		},
		{
			"name": "quoteIndicator",
			"type": [
				"null",
				"string"
			],
			"doc": "Flag indicating if sales order is a quote",
			"default": null
		},
		{
			"name": "carryoutIndicator",
			"type": [
				"null",
				"string"
			],
			"doc": "Flag indicating if sales order is a carryout",
			"default": null
		},
		{
			"name": "posEventCode",
			"type": [
				"null",
				"string"
			],
			"doc": "Code representing the current POS status of the Sales Order"
		},
		{
			"name": "timeOffset",
			"type": "string",
			"doc": "derived from site table, joined by vbap.werks"
		},
		{
			"name": "posEventDescription",
			"type": [
				"null",
				"string"
			],
			"doc": "Description of the POS Event Code"
		},
		{
			"name": "salesOrderOriginCode",
			"type": [
				"null",
				"string"
			],
			"doc": "Code representing the origin/creation source of the Sales Order"
		},
		{
			"name": "employeeIdCreatedBy",
			"type": [
				"null",
				"string"
			],
			"doc": "Employee Id who created the Sales Order, this can be null for"
		},
		{
			"name": "employeeIdProcessedBy",
			"type": [
				"null",
				"string"
			],
			"doc": "Employee Id who processed/finalized the Sales Order. This can be null on creation, then populated when the Finalize POS EVENT occurs"
		},
		{
			"name": "returnTypeCode",
			"type": [
				"null",
				"string"
			],
			"doc": "When the SalesOrderReceiptDocumentTypeCode = ' RE' then 1 = Adjustment, 2 = Return, 3 = Tradein, '-' = NA, not a ZRE"
		},
		{
			"name": "referenceSalesOrderIdentifier",
			"type": [
				"null",
				"string"
			],
			"doc": "If a Sales Order is a Return, Adjustment or Trade-In this is the ID of the other 1/2 of the transaction.  ZOR & ZRE are a pair"
		},
		{
			"name": "taxExemptCertificateNumber",
			"type": [
				"null",
				"string"
			],
			"doc": "Sales Tax Exemption certificate number. This number represents that the customer is not the end consumer of the product being purchased and should not be charged Sales Tax"
		},
		{
			"name": "salesOrderReasonCode",
			"type": [
				"null",
				"string"
			],
			"doc": "3 character code the indicates the reason the Sales Order was cancelled. Blank/Null when Sales Order has not been cancelled"
		},
		{
			"name": "salesOrderReasonDescription",
			"type": [
				"null",
				"string"
			],
			"doc": "Description of the Sales Order Cancellation Reason"
		},
		{
			"name": "datasphereTimestampVbak",
			"type": [
				"null",
				"string"
			],
			"doc": "Last Modified timestamp on Vbak from Datasphere",
			"default": null
		},
		{
			"name": "datasphereTimestampVbap",
			"type": [
				"null",
				"string"
			],
			"doc": "Last Modified timestamp on Vbap  from Datasphere",
			"default": null
		},
		{
			"name": "datasphereTimestampVbfa",
			"type": [
				"null",
				"string"
			],
			"doc": "Last Modified timestamp on Vbfa  from Datasphere",
			"default": null
		},
		{
			"name": "datasphereTimestampVbuk",
			"type": [
				"null",
				"string"
			],
			"doc": "Last Modified timestamp on Vbuk  from Datasphere",
			"default": null
		},
		{
			"name": "datasphereTimestampVbrp",
			"type": [
				"null",
				"string"
			],
			"doc": "Last Modified timestamp on Vbrp  from Datasphere",
			"default": null
		},
		{
			"name": "sapRowCreationTimestampVbak",
			"type": [
				"null",
				"string"
			],
			"doc": "Last Modified timestamp on Vbak from SAP ECC",
			"default": null
		},
		{
			"name": "sapRowCreationTimestampVbap",
			"type": [
				"null",
				"string"
			],
			"doc": "Last Modified timestamp on Vbap from SAP ECC",
			"default": null
		},
		{
			"name": "sapRowCreationTimestampVbfa",
			"type": [
				"null",
				"string"
			],
			"doc": "Last Modified timestamp on Vbfa from SAP ECC",
			"default": null
		},
		{
			"name": "sapRowCreationTimestampVbrp",
			"type": [
				"null",
				"string"
			],
			"doc": "Last Modified timestamp on Vbrp from SAP ECC",
			"default": null
		},
		{
			"name": "promotions",
			"type": {
				"type": "array",
				"items": {
					"type": "record",
					"name": "SalesOrderPromotion",
					"fields": [
						{
							"name": "salesOrderLineItemNumber",
							"type": "int",
							"doc": "Sales order line item number (sequence number)"
						},
						{
							"name": "headerPromotionTypeCode",
							"type": "string",
							"doc": "Unique identifier indicating the type of promotion"
						},
						{
							"name": "headerPromotionTypeDescription",
							"type": [
								"null",
								"string"
							],
							"doc": "Description of promotion type used on sales order",
							"default": null
						},
						{
							"name": "headerPromotionAmount",
							"type": "float",
							"doc": "Amount applied as Sales Order Header Promotion (it could match one Sales Order \"Promotion Only\" Line Item (TBC)"
						},
						{
							"name": "headerPromotionArticleNumber",
							"type": [
								"null",
								"string"
							],
							"doc": "Article Number of the Promotion. All promotions currently have an article number, so even though it is a \"header\" level promotion it is still added as line item.",
							"default": null
						}
					]
				}
			},
			"doc": "Collection of Promotions associated to the Sales Order Header",
			"default": []
		},
		{
			"name": "lineItems",
			"type": {
				"type": "array",
				"items": {
					"type": "record",
					"name": "SalesOrderLineItem",
					"fields": [
						{
							"name": "salesOrderLineItemNumber",
							"type": "int",
							"doc": "Sales order line item number (sequence number)"
						},
						{
							"name": "salesOrderLineItemTypeCode",
							"type": "string",
							"doc": "Unique record identifier indicating the type of sales order line item"
						},
						{
							"name": "salesOrderLineItemTypeDescription",
							"type": [
								"null",
								"string"
							],
							"doc": "Description of  line item type In the sales order line item",
							"default": null
						},
						{
							"name": "salesOrderLineItemStatusCode",
							"type": [
								"null",
								"string"
							],
							"doc": "Sales Order Line Item Status Unique record Id generated by the system",
							"default": null
						},
						{
							"name": "salesOrderLineItemStatusDescription",
							"type": [
								"null",
								"string"
							],
							"doc": "Sales Order Line Item Status Description",
							"default": null
						},
						{
							"name": "articleNumber",
							"type": "string",
							"doc": "Unique Article number of the current line item in the sales order"
						},
						{
							"name": "articleDescription",
							"type": "string",
							"doc": "Description of article unit"
						},
						{
							"name": "soldQuantity",
							"type": "float",
							"doc": "Quantity of items sold for each line item (Number of Sales Items)"
						},
						{
							"name": "retailPrice",
							"type": "float",
							"doc": "Price of individual article"
						},
						{
							"name": "discountAmount",
							"type": "float",
							"doc": "Price Discount to article"
						},
						{
							"name": "netPrice",
							"type": "float",
							"doc": "Price of article after any discounts and promotions have been applied"
						},
						{
							"name": "managerDeviationAmount",
							"type": "float",
							"doc": "Amount taken off the sales order set by the store manager based on price reason"
						},
						{
							"name": "priceReasonDescription",
							"type": [
								"null",
								"string"
							],
							"doc": "Reason for Price deviation from retail (Customer Satisfaction, Price Match, etc.)",
							"default": null
						},
						{
							"name": "certificateRedeemedQuantity",
							"type": "float",
							"doc": "Quantity of DT Certificates redeemed"
						},
						{
							"name": "MVIArticleIndicator",
							"type": "boolean",
							"doc": "X indicates that this miscellaneous article was created via the MVI application"
						},
						{
							"name": "dotNumber",
							"type": [
								"null",
								"string"
							],
							"doc": "Department of Transportation Mfg/Lot/Date Number",
							"default": null
						},
						{
							"name": "environmentalArticleNumber",
							"type": [
								"null",
								"string"
							],
							"doc": "Article Number of the Environmental Fee that is mandatory in some states",
							"default": null
						},
						{
							"name": "studEnvironmentalFeeArticleNumber",
							"type": [
								"null",
								"string"
							],
							"doc": "Article Number of the Environmental Fee for studded tires",
							"default": null
						},
						{
							"name": "vehicleGenericCategory",
							"type": [
								"null",
								"string"
							],
							"doc": "Major type of vehicle, present when not a standard vehicle (Ex. Trailer, Classic, etc.)",
							"default": null
						},
						{
							"name": "vehicleGenericSubCategory",
							"type": [
								"null",
								"string"
							],
							"doc": "Sub Category of vehicle, present when not a standard vehicle (Ex. Recreational, Utility, etc.)",
							"default": null
						},
						{
							"name": "certificateRedeemedIndicator",
							"type": "boolean",
							"doc": "Was a Discount Tire certificate redeemed in the purchase of this article (Y/N)"
						},
						{
							"name": "orderReasonCode",
							"type": [
								"null",
								"string"
							],
							"doc": "Code representing the reason the article listed on the sales order line item was ordered",
							"default": null
						},
						{
							"name": "orderReasonDescription",
							"type": [
								"null",
								"string"
							],
							"doc": "Corresponding description of the order reason code",
							"default": null
						},
						{
							"name": "adjustmentTypeCode",
							"type": [
								"null",
								"string"
							],
							"doc": "Code representing the type of adjustment if the article listed on the sales order line item was returned",
							"default": null
						},
						{
							"name": "adjustmentTypeDescription",
							"type": [
								"null",
								"string"
							],
							"doc": "Corresponding description of the adjustment type",
							"default": null
						},
						{
							"name": "adjustmentArticleTreadDepth",
							"type": [
								"null",
								"int"
							],
							"doc": "Tread depth of the returned article",
							"default": null
						},
						{
							"name": "adjustmentArticleCurrentMileage",
							"type": [
								"null",
								"int"
							],
							"doc": "Current mileage of the returned article",
							"default": null
						},
						{
							"name": "returnReasonCode",
							"type": [
								"null",
								"string"
							],
							"doc": "Code representing the reason the article listed on the sales order line item was returned (determined from the order reason)",
							"default": null
						},
						{
							"name": "salesOrderLineItemCreatedDate",
							"type": "string",
							"doc": "Timestamp identifying the date and time the sales order line item record was created by the system"
						},
						{
							"name": "lineItemCancellationCode",
							"type": [
								"null",
								"string"
							],
							"doc": "Code indicating the reason for the line item logical deletion. When blank this indicates a non-deleted line item",
							"default": null
						},
						{
							"name": "lineItemCancellationDescription",
							"type": [
								"null",
								"string"
							],
							"doc": "Line item cancellation reason description. When blank this indicates a non-deleted line item",
							"default": null
						},
						{
							"name": "miscArticleSizeDescription",
							"type": [
								"null",
								"string"
							],
							"doc": "Size description for miscellaneous articles. Will only be populated for miscellanous(non DT catalog) articles",
							"default": null
						},
						{
							"name": "adjustmentArticleInstallMileage",
							"type": [
								"null",
								"int"
							],
							"doc": "The mileage when the article being adjusted was installed",
							"default": null
						},
						{
							"name": "parentLineItemNumber",
							"type": [
								"null",
								"int"
							],
							"doc": "The line item which this line item relates to. Typically used for adjustments or fees to indicate which line item they apply to",
							"default": null
						},
						{
							"name": "promotions",
							"type": {
								"type": "array",
								"items": {
									"type": "record",
									"name": "SalesOrderLineItemPromotion",
									"fields": [
										{
											"name": "lineItemPromotionTypeCode",
											"type": "string",
											"doc": "Sales Order Receipt line item promotion type associated on sales order line item"
										},
										{
											"name": "lineItemPromotionTypeDescription",
											"type": [
												"null",
												"string"
											],
											"doc": "Description of promotion used on sales order line item",
											"default": null
										},
										{
											"name": "lineItemPromotionAmount",
											"type": "float",
											"doc": "Amount applied as Sales Order Line Item Promotion"
										},
										{
											"name": "lineItemPromotionArticleNumber",
											"type": [
												"null",
												"string"
											],
											"doc": "Article Number of the Promotion. All promotions currently have an article number, current design (oms) supports one line level promotion article",
											"default": null
										}
									]
								}
							},
							"doc": "Collection of Promotion associated to the Sales Order Line Item",
							"default": []
						},
						{
							"name": "taxes",
							"type": {
								"type": "array",
								"items": {
									"type": "record",
									"name": "SalesOrderLineItemTax",
									"fields": [
										{
											"name": "lineItemTaxTypeCode",
											"type": "string",
											"doc": "Unique identifier indicating Type of Tax associated on sales order line item"
										},
										{
											"name": "lineItemTaxTypeDescription",
											"type": [
												"null",
												"string"
											],
											"doc": "Description of Kind of tax being added to the sales order line item (city, county, state, federal, etc)",
											"default": null
										},
										{
											"name": "lineItemTaxAmount",
											"type": "float",
											"doc": "Amount applied as Sales Order Line Item Tax"
										}
									]
								}
							},
							"doc": "Collection of Taxes associated to the Sales Order Line Item",
							"default": []
						},
						{
							"name": "fees",
							"type": {
								"type": "array",
								"items": {
									"type": "record",
									"name": "SalesOrderLineItemFee",
									"fields": [
										{
											"name": "lineItemFeeTypeCode",
											"type": "string",
											"doc": "Sales Order Line Item fee type associated on sales order line item"
										},
										{
											"name": "lineItemFeeTypeDescription",
											"type": [
												"null",
												"string"
											],
											"doc": "Description of Kind of Fee being added to the sales order line item (environmental, disposal, etc)",
											"default": null
										},
										{
											"name": "lineItemFeeAmount",
											"type": "float",
											"doc": "Amount applied as Sales Order Line Item Fee"
										}
									]
								}
							},
							"doc": "Collection of Fees associated to the Sales Order Line Item",
							"default": []
						}
					]
				}
			},
			"doc": "Collection of Line Items associated to the Sales Order",
			"default": []
		},
		{
			"name": "receipts",
			"type": {
				"type": "array",
				"items": {
					"type": "record",
					"name": "SalesOrderReceipt",
					"fields": [
						{
							"name": "salesOrderReceiptIdentifier",
							"type": "string",
							"doc": "Sales Order Receipt unique identifier number generated by the system"
						},
						{
							"name": "salesOrderReceiptPostingDate",
							"type": "string",
							"doc": "Date the sales order delivery was received"
						}
					]
				}
			},
			"doc": "Collection of Sales Order Receipts (invoices, billing documents) associated with the Sales Order",
			"default": []
		}
	]
}