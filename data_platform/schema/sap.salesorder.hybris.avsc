{
  "type": "record",
  "name": "hybris",
  "namespace": "com.canonicla.sap.salesorder",
  "fields": [
    {
      "name": "hybrisSalesOrderIdentifier",
      "type": "string",
      "doc": "Unique sales order identifier generated by the system"
    },
    {
      "name": "orderTreadwellSessionIdentifier",
      "type": ["null", "string"],
      "doc": "Unique session identifier number generated by the system",
      "default": null
    },
    {
      "name": "insertDateTimestamp",
      "type": "string",
      "doc": "Date and timestamp that the record was created in Hybris"
    },
    {
      "name": "items",
      "type": {
        "type": "array",
        "items": {
          "type": "record",
          "name": "SalesOrderItem",
          "fields": [
            {
              "name": "hybrisSalesOrderLineItemNumber",
              "type": "int",
              "doc": "Unique sequence number of the specific line item"
            },
            {
              "name": "itemTreadwellSessionIdentifier",
              "type": ["null", "string"],
              "doc": "Unique session identifier number generated by the system that pulled the current article in the sales order line item",
              "default": null
            }
          ]
        }
      },
      "doc": "Sales Order Item - Collection of items contained within a Sales Order",
      "default": []
    }
  ]
}
