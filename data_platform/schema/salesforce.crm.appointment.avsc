{
  "type": "record",
  "name": "appointment",
  "namespace": "com.canonicla.salesforce.crm",
  "fields": [
    {
      "name": "appointmentIdentifier",
      "type": "string",
      "doc": "Unique record identifier generated by the system identifying the appointment"
    },
    {
      "name": "appointmentNumber",
      "type": "string",
      "doc": "Unique number generated by the system identifying the appointment"
    },
    {
      "name": "appointmentTypeName",
      "type": ["null", "string"],
      "doc": "Name of the type of appointment determined by scheduled consult or scheduled service (Front Room or Back Room)",
      "default": null
    },
    {
      "name": "appointmentDate",
      "type": ["null", "string"],
      "doc": "Date of scheduled appointment",
      "default": null
    },
    {
      "name": "workOrderIdentifier",
      "type": "string",
      "doc": "Unique record identifier of the parent work order of the appointment"
    },
    {
      "name": "salesOrderIdentifier",
      "type": "string",
      "doc": "Unique record identifier of the sales order associated to the parent work order of the appointment"
    },
    {
      "name": "siteNumber",
      "type": "string",
      "doc": "Site number relevant to the appointment"
    },
    {
      "name": "customerIdentifier",
      "type": ["null", "string"],
      "doc": "Unique record identifier identifying the customer associated to the appointment",
      "default": null
    },
    {
      "name": "customerTypeName",
      "type": ["null", "string"],
      "doc": "Indicates whether a customer is a fleet customer (organization/B2B) or retail customer (person/individual)",
      "default": null
    },
    {
      "name": "customerVehicleIdentifier",
      "type": ["null", "string"],
      "doc": "Unique record identifier of the customer vehicle to be serviced during the appointment",
      "default": null
    },
    {
      "name": "vehicleIdentifier",
      "type": ["null", "string"],
      "doc": "Unique record identifier identifying the vehicle associated to the appointment",
      "default": null
    },
    {
      "name": "trimIdentifier",
      "type": ["null", "string"],
      "doc": "Unique record identfier identifying the trim level of the vehicle associated to the appointment",
      "default": null
    },
    {
      "name": "assemblyIdentifier",
      "type": ["null", "string"],
      "doc": "Unique record identfier identifying the assembly of the vehicle associated to the appointment",
      "default": null
    },
    {
      "name": "statusCode",
      "type": ["null", "string"],
      "doc": "Code indicating the status of the appointment",
      "default": null
    },
    {
      "name": "bookingOriginCode",
      "type": ["null", "string"],
      "doc": "Name of source through which appointment was booked (Web, POS)",
      "default": null
    },
    {
      "name": "orderTypeName",
      "type": ["null", "string"],
      "doc": "Name of type of sales order (BOPIS, ROPIS, StoreOrder, ServiceAppointment, Invoice, Layaway, Quote) associated with work order",
      "default": null
    },
    {
      "name": "scheduledStartTimestamp",
      "type": ["null", "string"],
      "doc": "Time the appointment is scheduled to start",
      "default": null
    },
    {
      "name": "scheduledEndTimestamp",
      "type": ["null", "string"],
      "doc": "Time the appointment is scheduled to end",
      "default": null
    },
    {
      "name": "scheduledDuration",
      "type": ["null", "double"],
      "doc": "Scheduled duration of the appointment based on the scheduled start and end timestamps",
      "default": null
    },
    {
      "name": "actualStartTimestamp",
      "type": ["null", "string"],
      "doc": "Actual appointment start timestamp when appointment begins and vehicle is 'Bayed In'",
      "default": null
    },
    {
      "name": "actualEndTimestamp",
      "type": ["null", "string"],
      "doc": "Actual appointment end timestamp when appointment is complete and vehicle is 'Bayed Out'",
      "default": null
    },
    {
      "name": "actualDuration",
      "type": ["null", "double"],
      "doc": "Actual duration of the appointment based on the 'Bayed In' and 'Bayed Out' timestamps",
      "default": null
    },
    {
      "name": "createTimestamp",
      "type": ["null", "string"],
      "doc": "Time the appointment record was created",
      "default": null
    },
    {
      "name": "lastModifyTimestamp",
      "type": ["null", "string"],
      "doc": "Time the appointment record was last modified",
      "default": null
    },
    {
      "name": "timeOffset",
      "type": ["null", "string"],
      "doc": "Time difference in hours between the local timestamp and the coordinated universal timestamp (UTC)",
      "default": null
    },
    {
      "name": "slotReservations",
      "type": {
        "type": "array",
        "items": {
          "type": "record",
          "name": "AppointmentSlotReservation",
          "fields": [
            {
              "name": "slotReservationIdentifier",
              "type": "string",
              "doc": "Unique record identifier generated by the system identifying the appointment slot reservation relevant to the appointment"
            },
            {
              "name": "slotReservationTypeCode",
              "type": ["null", "string"],
              "doc": "Code denoting the type of appointment, appointment booking origin, and customer type",
              "default": null
            },
            {
              "name": "displayAppointmentIdentifier",
              "type": ["null", "string"],
              "doc": "Appointment ID displayed on the UI",
              "default": null
            },
            {
              "name": "createTimestamp",
              "type": ["null", "string"],
              "doc": "Time the appointment slot reservation was created",
              "default": null
            },
            {
              "name": "lastModifyTimestamp",
              "type": ["null", "string"],
              "doc": "Time the appointment slot reservation was last modified",
              "default": null
            },
            {
              "name": "slotIdentifier",
              "type": "string",
              "doc": "Unique record identifier of the appointment slot relevant to a store's appointment slot configuration"
            }
          ]
        }
      },
      "doc": "collection of appointment slot reservations created to satisfy the appointment associated to the work order",
      "default": []
    },
    {
      "name": "tasks",
      "type": {
        "type": "array",
        "items": {
          "type": "record",
          "name": "AppointmentTask",
          "fields": [
            {
              "name": "workOrderLineItemIdentifier",
              "type": "string",
              "doc": "Work Order Line Item unique record identifier generated by the system identifying a single line item entry on the work order"
            },
            {
              "name": "articleNumber",
              "type": ["null", "string"],
              "doc": "Unique number identifying the article listed on the work order line item",
              "default": null
            },
            {
              "name": "articleTypeCode",
              "type": ["null", "string"],
              "doc": "Code identifying the type of article listed on the work order line item",
              "default": null
            },
            {
              "name": "articleQuantity",
              "type": ["null", "double"],
              "doc": "Count of articles required to fulfill the work order line item",
              "default": null
            },
            {
              "name": "sequenceNumber",
              "type": ["null", "string"],
              "doc": "Order in which each work order line item will be performed",
              "default": null
            },
            {
              "name": "articleUnitPriceAmount",
              "type": ["null", "double"],
              "doc": "The unit price of the article, in dollars",
              "default": null
            },
            {
              "name": "articleUnitPriceDiscountAmount",
              "type": ["null", "double"],
              "doc": "The discounted unit price of the article, in dollars, for use in work order receipt",
              "default": null
            }
          ]
        }
      },
      "doc": "collection of work order line items to be completed during the appointment",
      "default": []
    }
  ]
}
