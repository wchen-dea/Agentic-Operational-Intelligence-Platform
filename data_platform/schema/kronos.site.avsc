{
  "type": "record",
  "name": "site",
  "namespace": "com.canonicla.kronos",
  "fields": [
    {
      "name": "siteNumber",
      "type": "string",
      "doc": "Unique record Id generated by the system identifying a specific site and/or store"
    },
    {
      "name": "siteDescription",
      "type": ["null", "string"],
      "doc": "Description of the site",
      "default": null
    },
    {
      "name": "siteName",
      "type": "string",
      "doc": "Name of the site"
    },
    {
      "name": "siteTypeCode",
      "type": "string",
      "doc": "Code representing the type of site"
    },
    {
      "name": "businessUnitCode",
      "type": ["null", "string"],
      "doc": "Code representing the Business Unit relevant to a Site",
      "default": null
    },
    {
      "name": "businessUnitName",
      "type": ["null", "string"],
      "doc": "Name of business unit",
      "default": null
    },
    {
      "name": "companyCode",
      "type": "string",
      "doc": "Code representing the company associated to a Site"
    },
    {
      "name": "internalVendorNumber",
      "type": ["null", "string"],
      "doc": "Internal Discount Tire Vendor Number for inter-site transactions",
      "default": null
    },
    {
      "name": "internalCustomerNumber",
      "type": ["null", "string"],
      "doc": "Internal Discount Tire Customer Number for inter-site transactions",
      "default": null
    },
    {
      "name": "regionCode",
      "type": ["null", "string"],
      "doc": "Region Unique number identifier generated by SAP",
      "default": null
    },
    {
      "name": "E3RegionCode",
      "type": ["null", "string"],
      "doc": "",
      "default": null
    },
    {
      "name": "regionName",
      "type": ["null", "string"],
      "doc": "Name of region",
      "default": null
    },
    {
      "name": "openDate",
      "type": ["null", "string"],
      "doc": "Date store initially opened for business",
      "default": null
    },
    {
      "name": "openIndicator",
      "type": "string",
      "doc": "Flag indicating store is active and open for businessDate site was created"
    },
    {
      "name": "siteCreateDate",
      "type": ["null", "string"],
      "doc": "Date site was created",
      "default": null
    },
    {
      "name": "certificateOfOccupancyDate",
      "type": ["null", "string"],
      "doc": "Date building inspector issued certificate of occupancy",
      "default": null
    },
    {
      "name": "storeSalesCloseDate",
      "type": ["null", "string"],
      "doc": "Date of sales closure for a site",
      "default": null
    },
    {
      "name": "storeGeneralLedgerCloseDate",
      "type": ["null", "string"],
      "doc": "Date of financial closure for a site",
      "default": null
    },
    {
      "name": "storeBusinessCloseDate",
      "type": ["null", "string"],
      "doc": "Date of official business closure for a site",
      "default": null
    },
    {
      "name": "temporaryCloseDate",
      "type": ["null", "string"],
      "doc": "Date site is temporarily closed",
      "default": null
    },
    {
      "name": "reopenForBusinessDate",
      "type": ["null", "string"],
      "doc": "Date site reopens for business following temporary closure",
      "default": null
    },
    {
      "name": "salesOrganizationCode",
      "type": ["null", "string"],
      "doc": "Code representing the sales organization relevant to a site",
      "default": null
    },
    {
      "name": "purchasingOrganizationNumber",
      "type": ["null", "string"],
      "doc": "Number representing the purchasing organization relevant to a site",
      "default": null
    },
    {
      "name": "divisionCode",
      "type": ["null", "string"],
      "doc": "Code representing the business division relevant to a site",
      "default": null
    },
    {
      "name": "localCurrencyCode",
      "type": ["null", "string"],
      "doc": "Code representing the local currency relevant to a site",
      "default": null
    },
    {
      "name": "taxTradeInIndicator",
      "type": ["null", "string"],
      "doc": "Flag indicating if a site charges tax for trade-in articles",
      "default": null
    },
    {
      "name": "valuationAreaCode",
      "type": ["null", "string"],
      "doc": "Code representing the valuation area relevant to a site",
      "default": null
    },
    {
      "name": "ecoMinutesCode",
      "type": ["null", "string"],
      "doc": "",
      "default": null
    },
    {
      "name": "blockingReasonCode",
      "type": "string",
      "doc": "Code representing a blocking reason for a store"
    },
    {
      "name": "blockingReasonDescription",
      "type": ["null", "string"],
      "doc": "Description of blocking reason",
      "default": null
    },
    {
      "name": "storageCapacityNumber",
      "type": ["null", "string"],
      "doc": "Maximum storage capacity of a Site",
      "default": null
    },
    {
      "name": "logisticsCalendarCode",
      "type": ["null", "string"],
      "doc": "Code representing the logistics calendar of a Site",
      "default": null
    },
    {
      "name": "distributionChannelCode",
      "type": ["null", "string"],
      "doc": "Code representing a specific Distribution Center relevant to a Site",
      "default": null
    },
    {
      "name": "address",
      "type": [
        "null",
        {
          "type": "record",
          "name": "SiteAddress",
          "fields": [
            {
              "name": "siteAddress",
              "type": ["null", "string"],
              "doc": "Street address of the site",
              "default": null
            },
            {
              "name": "siteCityName",
              "type": ["null", "string"],
              "doc": "Name of the city a site is located in",
              "default": null
            },
            {
              "name": "siteCountyName",
              "type": ["null", "string"],
              "doc": "Name of the county a site is located in",
              "default": null
            },
            {
              "name": "siteStateCode",
              "type": "string",
              "doc": "Code representing the state a site is located in"
            },
            {
              "name": "stateName",
              "type": ["null", "string"],
              "doc": "Name of state site is located in",
              "default": null
            },
            {
              "name": "siteZipCode",
              "type": ["null", "string"],
              "doc": "Zip code the store is located in",
              "default": null
            },
            {
              "name": "GISPostalCode",
              "type": ["null", "string"],
              "doc": "Geographic Information System postal code for a site",
              "default": null
            },
            {
              "name": "countryCode",
              "type": ["null", "string"],
              "doc": "Code representing the country the site is located in",
              "default": null
            },
            {
              "name": "latitude",
              "type": ["null", "double"],
              "doc": "Latitude Coordinate value for the site location",
              "default": null
            },
            {
              "name": "longitude",
              "type": ["null", "double"],
              "doc": "Longitude Coordinate value for the site location",
              "default": null
            },
            {
              "name": "timeZoneCode",
              "type": ["null", "string"],
              "doc": "Code representing the time zone of the site",
              "default": null
            }
          ]
        }
      ],
      "doc": "SiteAddress object",
      "default": null
    },
    {
      "name": "store",
      "type": [
        "null",
        {
          "type": "record",
          "name": "SiteStore",
          "fields": [
            {
              "name": "storeCode",
              "type": "string",
              "doc": "Code representing the specific store"
            },
            {
              "name": "storeTypeCode",
              "type": ["null", "string"],
              "doc": "Internal code for type of speciality store (pit-pass, mobile, etc.)",
              "default": null
            },
            {
              "name": "storeGroupCode",
              "type": "string",
              "doc": "Code representing a specific group of stores"
            },
            {
              "name": "profitCenterIdentifier",
              "type": ["null", "string"],
              "doc": "Unique identifier number for stores that are profit centers",
              "default": null
            },
            {
              "name": "priceListCode",
              "type": ["null", "string"],
              "doc": "Code representing the price list relevant to a store",
              "default": null
            },
            {
              "name": "priceListName",
              "type": ["null", "string"],
              "doc": "Name of the price list relevant to a store",
              "default": null
            },
            {
              "name": "marketType",
              "type": ["null", "string"],
              "doc": "Code representing the stores position relative to the market place (e.g., highly competitive, leader, etc.)",
              "default": null
            }
          ]
        }
      ],
      "doc": "SiteStore object",
      "default": null
    },
    {
      "name": "regionalOffice",
      "type": [
        "null",
        {
          "type": "record",
          "name": "SiteRegionalOffice",
          "fields": [
            {
              "name": "regionalOfficeCode",
              "type": "string",
              "doc": "Code representing the Regional Office relevant to a Site"
            },
            {
              "name": "regionalOfficeName",
              "type": "string",
              "doc": "Name of the Regional Office relevant to a Site"
            }
          ]
        }
      ],
      "doc": "SiteRegionalOffice object",
      "default": null
    },
    {
      "name": "regionalWarehouse",
      "type": [
        "null",
        {
          "type": "record",
          "name": "SiteRegionalWarehouse",
          "fields": [
            {
              "name": "regionalWarehouseCode",
              "type": "string",
              "doc": "Code representing the Regional Warehouse relevant to a Site"
            }
          ]
        }
      ],
      "doc": "SiteRegionalWarehouse object",
      "default": null
    },
    {
      "name": "crossDock",
      "type": [
        "null",
        {
          "type": "record",
          "name": "SiteCrossDock",
          "fields": [
            {
              "name": "crossDockCode",
              "type": "string",
              "doc": "Code representing the Cross Dock relevant to a Site"
            }
          ]
        }
      ],
      "doc": "SiteCrossDock object",
      "default": null
    },
    {
      "name": "managedInventory",
      "type": [
        "null",
        {
          "type": "record",
          "name": "SiteManagedInventory",
          "fields": [
            {
              "name": "managedInventoryCode",
              "type": "string",
              "doc": "Code representing a Site that manages inventory"
            }
          ]
        }
      ],
      "doc": "SiteManagedInventory object",
      "default": null
    },
    {
      "name": "clusters",
      "type": {
        "type": "array",
        "items": {
          "type": "record",
          "name": "SiteCluster",
          "fields": [
            {
              "name": "storeClusterCode",
              "type": "string",
              "doc": "Code representing the store cluster relevant to a store (e.g., Vehicle Cluster, Mileage Cluster, Weather Cluster)"
            },
            {
              "name": "storeClusterName",
              "type": "string",
              "doc": "Name of the store cluster relevant to a store (e.g., Vehicle Cluster, Mileage Cluster, Weather Cluster)"
            },
            {
              "name": "storeClusterTypeCode",
              "type": "string",
              "doc": "Code representing the type of store cluster relevant to a store (e.g., Vehicle Cluster, Mileage Cluster, Weather Cluster)"
            }
          ]
        }
      },
      "doc": "array of SiteCluster objects",
      "default": []
    }
  ]
}
