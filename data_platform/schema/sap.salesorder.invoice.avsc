{
	"type": "record",
	"name": "invoice",
	"namespace": "com.canonicla.sap.salesorder",
	"fields": [
		{
			"name": "salesOrderReceiptIdentifier",
			"type": "string",
			"doc": "Sales Order Receipt unique identifier generated by the system"
		},
		{
			"name": "salesOrderIdentifier",
			"type": "string",
			"doc": "Sales Order unique identifier corresponding to the current sales receipt"
		},
		{
			"name": "salesOrderReceiptDocumentTypeCode",
			"type": "string",
			"doc": "Code indicating the type of sales order receipt"
		},
		{
			"name": "salesOrderReceiptDocumentTypeDescription",
			"type": "string",
			"doc": "Description of receipt being given to the customer as part of the sales order"
		},
		{
			"name": "salesOrderReceiptPostingDate",
			"type": "string",
			"doc": "Date the sales order delivery was received"
		},
		{
			"name": "siteNumber",
			"type": "string",
			"doc": "Site unique identifier corresponding to the site where units and/or services were purchased/fulfilled"
		},
		{
			"name": "profitCenterCode",
			"type": "string",
			"doc": "Profit Center Code unique identifier of the profit center associated to the sales order receipt"
		},
		{
			"name": "customerIdentifier",
			"type": "string",
			"doc": "Customer (C360) unique identifier of the customer who was billed for units and/services"
		},
		{
			"name": "customerVehicleIdentifier",
			"type": [
				"null",
				"string"
			],
			"doc": "Unique identifier for a customer's vehicle that was serviced as part of a sales order",
			"default": null
		},
		{
			"name": "vehicleIdentifier",
			"type": [
				"null",
				"string"
			],
			"doc": "Vehicle Unique record Id identifying the brand, make, model, etc. of the customer's vehicle",
			"default": null
		},
		{
			"name": "trimIdentifier",
			"type": [
				"null",
				"string"
			],
			"doc": "Vehicle Trim Id denoting the trim level of the vehicle assigned to the work order",
			"default": null
		},
		{
			"name": "assemblyIdentifier",
			"type": [
				"null",
				"string"
			],
			"doc": "Vehicle Assembly Id denoting the assembly of the vehicle",
			"default": null
		},
		{
			"name": "liftIdentifier",
			"type": [
				"null",
				"string"
			],
			"doc": "Vehicle Lift Id",
			"default": null
		},
		{
			"name": "orderTransactionTypeCode",
			"type": "string",
			"doc": "Code representing the type of transaction that occured (01, 02, 03, 04, 05)"
		},
		{
			"name": "orderTransactionTypeDescription",
			"type": "string",
			"doc": "Description of the type of transaction that occured (01 - BOPIS, 02 - ROPIS, 03 - DTD, 04 - Serivce Appointment, 05 - Store Order)"
		},
		{
			"name": "lastModifyTimestamp",
			"type": [
				"null",
				"string"
			],
			"doc": "Timestamp identifying the date and time the sales order receipt was last modified",
			"default": null
		},
		{
			"name": "salesOrderReceiptCreatedDate",
			"type": "string",
			"doc": "Date the sales order receipt was last modified"
		},
		{
			"name": "quoteIndicator",
			"type": [
				"null",
				"string"
			],
			"doc": "Flag indicating if the order was a quote",
			"default": null
		},
		{
			"name": "carryoutIndicator",
			"type": [
				"null",
				"string"
			],
			"doc": "Flag indicating if the order was a carryout",
			"default": null
		},
		{
			"name": "hybrisCustomerNumber",
			"type": [
				"null",
				"string"
			],
			"doc": "Alternate unique identifier assigned to a new customer who purchased units and/or services using Hybris Product Browse",
			"default": null
		},
		{
			"name": "timeOffset",
			"type": "string",
			"doc": "Time difference in hours between the local timestamp and the coordinated universal timestamp (UTC). Extract using Site"
		},
		{
			"name": "returnTypeCode",
			"type": [
				"null",
				"string"
			],
			"doc": "When the SalesOrderReceiptDocumentTypeCode = ' RE' then 1 = Adjustment, 2 = Return, 3 = Tradein, '-' = NA, not an RE",
			"default": null
		},
		{
			"name": "referenceSalesOrderIdentifier",
			"type": [
				"null",
				"string"
			],
			"doc": "If this is a \"S1\" or \"S2\" document, this will be the Sales Order Identifier of the Order Being Cancelled/Reversed",
			"default": null
		},
		{
			"name": "datasphereTimestampVbrk",
			"type": [
				"null",
				"string"
			],
			"doc": "Last Modified timestamp on Vbrk from Datasphere",
			"default": null
		},
		{
			"name": "datasphereTimestampVbrp",
			"type": [
				"null",
				"string"
			],
			"doc": "Last Modified timestamp on Vbrp from Datasphere",
			"default": null
		},
		{
			"name": "datasphereTimestampVbak",
			"type": [
				"null",
				"string"
			],
			"doc": "Last Modified timestamp on Vbap from Datasphere",
			"default": null
		},
		{
			"name": "datasphereTimestampVbap",
			"type": [
				"null",
				"string"
			],
			"doc": "Last Modified timestamp on Vbap from Datasphere",
			"default": null
		},
		{
			"name": "sapRowCreationTimestampVbrk",
			"type": [
				"null",
				"string"
			],
			"doc": "Last Modified timestamp on Vbrk from Datasphere",
			"default": null
		},
		{
			"name": "sapRowCreationTimestampVbrp",
			"type": [
				"null",
				"string"
			],
			"doc": "Last Modified timestamp on Vbrp from Datasphere",
			"default": null
		},
		{
			"name": "sapRowCreationTimestampVbak",
			"type": [
				"null",
				"string"
			],
			"doc": "Last Modified timestamp on Vbak from Datasphere",
			"default": null
		},
		{
			"name": "sapRowCreationTimestampVbap",
			"type": [
				"null",
				"string"
			],
			"doc": "Last Modified timestamp on Vbap from Datasphere",
			"default": null
		},
		{
			"name": "promotions",
			"type": {
				"type": "array",
				"items": {
					"type": "record",
					"name": "SalesOrderReceiptPromotion",
					"fields": [
						{
							"name": "salesOrderReceiptLineItemNumber",
							"type": "int",
							"doc": "Sales order receipt line item number (sequence number)"
						},
						{
							"name": "headerPromotionTypeCode",
							"type": "string",
							"doc": "Unique identifier indicating the type of promotion that was applied to the sales order"
						},
						{
							"name": "headerPromotionTypeDescription",
							"type": [
								"null",
								"string"
							],
							"doc": "Description of promotion type used on sales order",
							"default": null
						},
						{
							"name": "headerPromotionAmount",
							"type": "float",
							"doc": "Actual amount of money customer receives off due to promotion"
						},
						{
							"name": "headerPromotionArticleNumber",
							"type": [
								"null",
								"string"
							],
							"doc": "Unique article number corresponding to the promotion applied to the sales order",
							"default": null
						}
					]
				}
			},
			"doc": "SalesOrderReceiptPromotion is an optional collection of header promotions applied to the order",
			"default": []
		},
		{
			"name": "lineItems",
			"type": {
				"type": "array",
				"items": {
					"type": "record",
					"name": "SalesOrderReceiptLineItem",
					"fields": [
						{
							"name": "salesOrderReceiptLineItemNumber",
							"type": "int",
							"doc": "Sales order receipt line item number (sequence number)"
						},
						{
							"name": "salesOrderLineItemNumber",
							"type": "int",
							"doc": "Sales order line item number (sequence number)"
						},
						{
							"name": "salesOrderReceiptLineItemTypeCode",
							"type": "string",
							"doc": "Unique record identifier indicating the type of sales order receipt line item"
						},
						{
							"name": "salesOrderReceiptLineItemTypeDescription",
							"type": [
								"null",
								"string"
							],
							"doc": "Description of sales order receipt line item type",
							"default": null
						},
						{
							"name": "articleNumber",
							"type": "string",
							"doc": "Unique article number of the current line item in the sales order receipt"
						},
						{
							"name": "articleDescription",
							"type": "string",
							"doc": "Description of article unit"
						},
						{
							"name": "soldQuantity",
							"type": "int",
							"doc": "Quantity of units sold for the current sales order receipt line item"
						},
						{
							"name": "retailPrice",
							"type": "float",
							"doc": "Price of individual article"
						},
						{
							"name": "discountAmount",
							"type": "float",
							"doc": "Price Discount to article"
						},
						{
							"name": "netPrice",
							"type": "float",
							"doc": "Price of article after any discounts and promotions have been applied"
						},
						{
							"name": "managerDeviationAmount",
							"type": "float",
							"doc": "Amount taken off the sales order receipt set by the store manager based on price reason"
						},
						{
							"name": "priceReasonDescription",
							"type": [
								"null",
								"string"
							],
							"doc": "Reason for Price deviation from retail (Customer Satisfaction, Price Match, etc.)",
							"default": null
						},
						{
							"name": "certificateRedeemedQuantity",
							"type": "float",
							"doc": "Quantity of DT Certificates redeemed"
						},
						{
							"name": "MVIArticleIndicator",
							"type": "boolean",
							"doc": "X indicates that this miscellaneous article was created via the MVI application"
						},
						{
							"name": "dotNumber",
							"type": [
								"null",
								"string"
							],
							"doc": "Department of Transportation Mfg/Lot/Date Number",
							"default": null
						},
						{
							"name": "environmentalArticleNumber",
							"type": [
								"null",
								"string"
							],
							"doc": "Article Number of the Environmental Fee that is mandatory in some states",
							"default": null
						},
						{
							"name": "studEnvironmentalFeeArticleNumber",
							"type": [
								"null",
								"string"
							],
							"doc": "Article Number of the Environmental Fee for studded tires",
							"default": null
						},
						{
							"name": "vehicleGenericCategory",
							"type": [
								"null",
								"string"
							],
							"doc": "Major type of vehicle, present when not a standard vehicle (Ex. Trailer, Classic, etc.)",
							"default": null
						},
						{
							"name": "vehicleGenericSubCategory",
							"type": [
								"null",
								"string"
							],
							"doc": "Sub Category of vehicle, present when not a standard vehicle (Ex. Recreational, Utility, etc.)",
							"default": null
						},
						{
							"name": "certificateRedeemedIndicator",
							"type": "boolean",
							"doc": "Was a Discount Tire certificate redeemed in the purchase of this article (Y/N)"
						},
						{
							"name": "orderReasonCode",
							"type": [
								"null",
								"string"
							],
							"doc": "Code representing the reason the article listed on the sales order receipt line item was ordered",
							"default": null
						},
						{
							"name": "orderReasonDescription",
							"type": [
								"null",
								"string"
							],
							"doc": "Corresponding description of the order reason code",
							"default": null
						},
						{
							"name": "adjustmentTypeCode",
							"type": [
								"null",
								"string"
							],
							"doc": "Code representing the type of adjustment if the article listed on the sales order receipt line item was returned",
							"default": null
						},
						{
							"name": "adjustmentTypeDescription",
							"type": [
								"null",
								"string"
							],
							"doc": "Corresponding description of the adjustment type",
							"default": null
						},
						{
							"name": "adjustmentArticleTreadDepth",
							"type": [
								"null",
								"int"
							],
							"doc": "Tread depth of the returned article",
							"default": null
						},
						{
							"name": "adjustmentArticleCurrentMileage",
							"type": [
								"null",
								"int"
							],
							"doc": "Current mileage of the returned article",
							"default": null
						},
						{
							"name": "returnReasonCode",
							"type": [
								"null",
								"string"
							],
							"doc": "Code representing the reason the article listed on the sales order receipt line item was returned (determined from the order reason)",
							"default": null
						},
						{
							"name": "extendedCost",
							"type": [
								"null",
								"float"
							],
							"doc": "Total cost for this line, quantity * unit cost",
							"default": null
						},
						{
							"name": "articleInstallMileage",
							"type": [
								"null",
								"int"
							],
							"doc": "Vehicle Mileage when Article Installed",
							"default": null
						},
						{
							"name": "salesOrderReceiptParentLineNumber",
							"type": [
								"null",
								"int"
							],
							"doc": "Parent Line Number for services, adjustments, etc.",
							"default": null
						},
						{
							"name": "itemGLChargeCode",
							"type": [
								"null",
								"string"
							],
							"doc": "Code indicates an override of the GL Charge, for example charge to Cert Revenue rather than Revenue.",
							"default": null
						},
						{
							"name": "promotions",
							"type": {
								"type": "array",
								"items": {
									"type": "record",
									"name": "SalesOrderReceiptLineItemPromotion",
									"fields": [
										{
											"name": "lineItemPromotionTypeCode",
											"type": "string",
											"doc": "Unique identifier indicating the type of promotion"
										},
										{
											"name": "lineItemPromotionTypeDescription",
											"type": [
												"null",
												"string"
											],
											"doc": "Description of promotion type used on sales order",
											"default": null
										},
										{
											"name": "lineItemPromotionAmount",
											"type": "float",
											"doc": "Actual amount of money customer receives off due to promotion"
										},
										{
											"name": "lineItemPromotionArticleNumber",
											"type": [
												"null",
												"string"
											],
											"doc": "Unique article number corresponding to the promotion applied to the sales order",
											"default": null
										}
									]
								}
							},
							"doc": "SalesOrderReceiptLineItemPromotion is an optional collection of promotions applied to the specific line item",
							"default": []
						},
						{
							"name": "taxes",
							"type": {
								"type": "array",
								"items": {
									"type": "record",
									"name": "SalesOrderReceiptLineItemTax",
									"fields": [
										{
											"name": "lineItemTaxTypeCode",
											"type": "string",
											"doc": "Unique identifier indicating Type of Tax being paid on sales order receipt line items"
										},
										{
											"name": "lineItemTaxTypeDescription",
											"type": [
												"null",
												"string"
											],
											"doc": "Description of kind of tax being added to the sales order",
											"default": null
										},
										{
											"name": "lineItemTaxAmount",
											"type": "float",
											"doc": "Amount of tax applied to the sales order receipt line item"
										}
									]
								}
							},
							"doc": "SalesOrderReceiptLineItemTax is an optional collection of taxes applied to the specific line item",
							"default": []
						},
						{
							"name": "fees",
							"type": {
								"type": "array",
								"items": {
									"type": "record",
									"name": "SalesOrderReceiptLineItemFee",
									"fields": [
										{
											"name": "lineItemFeeTypeCode",
											"type": "string",
											"doc": "Sales Order Receipt Line Item fee unique record identifier generated by the system"
										},
										{
											"name": "lineItemFeeTypeDescription",
											"type": [
												"null",
												"string"
											],
											"doc": "Sales Order Receipt fee unique record identifier number generated by the system",
											"default": null
										},
										{
											"name": "lineItemFeeAmount",
											"type": "float",
											"doc": "Unique identifier indicating Type of Tax being paid on sales order receipt"
										}
									]
								}
							},
							"doc": "SalesOrderReceiptLineItemFee is an optional collection of fees applied to the specific line item",
							"default": []
						},
						{
							"name": "allocations",
							"type": {
								"type": "array",
								"items": {
									"type": "record",
									"name": "SalesOrderReceiptLineItemAllocation",
									"fields": [
										{
											"name": "pricingConditionCode",
											"type": "string",
											"doc": "Code representing the pricing condition"
										},
										{
											"name": "generalLedgerAccountNumber",
											"type": "string",
											"doc": "General Ledger (GL) Account Unique number identifier generated by the system"
										},
										{
											"name": "allocationAmount",
											"type": "float",
											"doc": "Receipt amount in local currency by pricing condition code"
										}
									]
								}
							},
							"doc": "SalesOrderReceiptLineItemAllocation is an optional collection of pricing conditions (inclusive of promotions, taxes, fees, etc.) applied to the specific line item",
							"default": []
						}
					]
				}
			},
			"doc": "SalesOrderReceiptLineItem is a collection of line items that represent a unit or service that was purchased as part of the order",
			"default": []
		},
		{
			"name": "payments",
			"type": {
				"type": "array",
				"items": {
					"type": "record",
					"name": "SalesOrderReceiptPayment",
					"fields": [
						{
							"name": "paymentId",
							"type": "int",
							"doc": "Sequence number identifying the order in which the payment type that was used during the sale"
						},
						{
							"name": "paymentTypeCode",
							"type": "string",
							"doc": "Code representing the type of payment that was used during the sale"
						},
						{
							"name": "paymentTypeDescription",
							"type": [
								"null",
								"string"
							],
							"doc": "Description of payment type used during sales order",
							"default": null
						},
						{
							"name": "paymentAmount",
							"type": "float",
							"doc": "Amount paid using the current payment type"
						}
					]
				}
			},
			"doc": "SalesOrderReceiptPayment is an optional collection of payment types used by the customer to pay for the order",
			"default": []
		}
	]
}