{
  "type": "record",
  "name": "snapshot",
  "namespace": "com.canonicla.warehouse.inventory",
  "fields": [
    {
      "name": "siteNumber",
      "type": "string",
      "doc": "Unique record Id generated by the system identifying a specific site"
    },
    {
      "name": "articleNumber",
      "type": "string",
      "doc": "Name of the the article"
    },
    {
      "name": "inventoryDateTime",
      "type": "string",
      "doc": "Date of inventory check"
    },
    {
      "name": "onHandQuantity",
      "type": "int",
      "doc": "Quantity of stock present at given site"
    },
    {
      "name": "reservedQuantity",
      "type": "int",
      "doc": "Quanity of stock reserved at given site"
    },
    {
      "name": "availableQuantity",
      "type": "int",
      "doc": "Quantity of stock available for purchase at given site"
    },
    {
      "name": "inTransitQuantity",
      "type": "int",
      "doc": "Quantity of stock available for purchase at given site"
    },
    {
      "name": "layawayQuantity",
      "type": "int",
      "doc": "Quantity of stock available for purchase at given site"
    },
    {
      "name": "weborderQuantity",
      "type": "int",
      "doc": "Quantity of stock available for purchase at given site"
    },
    {
      "name": "purchaseDecisionCode",
      "type": "string",
      "doc": "Date of inventory check"
    },
    {
      "name": "purchaseDecisionDescription",
      "type": "string",
      "doc": "Date of inventory check"
    },
    {
      "name": "timeOffset",
      "type": "string",
      "doc": "Time difference in hours between the local timestamp and the coordinated universal timestamp (UTC)"
    }
  ]
}