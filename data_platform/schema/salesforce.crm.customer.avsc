{
  "type": "record",
  "name": "customer",
  "namespace": "com.canonicla.salesforce.crm",
  "fields": [
    {
      "name": "customerIdentifier",
      "type": "string",
      "doc": "Customer Number Unique record Id generated by the system"
    },
    {
      "name": "customerTypeCode",
      "type": "string",
      "doc": "Indicates whether a customer is an organization or individual"
    },
    {
      "name": "activeIndicator",
      "type": ["null", "boolean"],
      "doc": "Flag to indicate whether this is an active customer",
      "default": null
    },
    {
      "name": "myAccountIndicator",
      "type": ["boolean", "null"],
      "doc": "Flag to indicate whether customer is a my account (MACT) customer that has purchased while logged into MACT",
      "default": false
    },
    {
      "name": "blockedReasonCode",
      "type": ["null", "string"],
      "doc": "A number that corresponds to a reason the customer is blocked",
      "default": null
    },
    {
      "name": "createTimestamp",
      "type": "string",
      "doc": "Date & Time customer record was created"
    },
    {
      "name": "lastUpdateTimestamp",
      "type": ["null", "string"],
      "doc": "Date & Time customer record was updated",
      "default": null
    },
    {
      "name": "fraudulentIndicator",
      "type": ["boolean", "null"],
      "doc": "Flag denoting the account has been suspected of fraudulent transactions",
      "default": false
    },
    {
      "name": "draftIndicator",
      "type": ["boolean", "null"],
      "doc": "Flag indicating if this customer record is a draft",
      "default": false
    },
    {
      "name": "offlineCreationIndicator",
      "type": ["boolean", "null"],
      "doc": "Flag deonting of customer account was created offline",
      "default": false
    },
    {
      "name": "emailOptInIndicator",
      "type": ["null", "boolean"],
      "doc": "Flag denoting if customer has enrolled in automated email updates",
      "default": null
    },
    {
      "name": "synchronyCardholderIndicator",
      "type": ["boolean", "null"],
      "doc": "Flag indicating if customer is a synchrony card holder",
      "default": false
    },
    {
      "name": "timeOffset",
      "type": ["null", "string"],
      "doc": "Time difference in hours between the local timestamp and the coordinated universal timestamp (UTC)",
      "default": null
    },
    {
      "name": "organizationAttribute",
      "type": [
        "null",
        {
          "type": "record",
          "name": "CustomerOrganizationAttribute",
          "fields": [
            {
              "name": "organizationName",
              "type": ["null", "string"],
              "doc": "Name of organization if customer is a business",
              "default": null
            },
            {
              "name": "organizationLegalName",
              "type": ["null", "string"],
              "doc": "Full legal name of organization",
              "default": null
            },
            {
              "name": "arAccountNumber",
              "type": ["null", "string"],
              "doc": "Accounts Receivable account for Organization/company type customer",
              "default": null
            },
            {
              "name": "fleetAccountIdentifier",
              "type": ["null", "string"],
              "doc": "Unique record ID generated indicating",
              "default": null
            },
            {
              "name": "accountGroupNumber",
              "type": ["null", "string"],
              "doc": "Group this organization account might belong to",
              "default": null
            },
            {
              "name": "taxCertificateNumber",
              "type": ["null", "string"],
              "doc": "Organization Tax Identification Number (TIN)",
              "default": null
            },
            {
              "name": "taxClassificationIndicator",
              "type": ["null", "string"],
              "doc": "Indicates if customer is Tax exempt",
              "default": null
            },
            {
              "name": "paymentTypeCode",
              "type": ["null", "string"],
              "doc": "Indicates process used to pay for purchase (credit, debit, cash, etc.)",
              "default": null
            },
            {
              "name": "paymentTermsCode",
              "type": ["null", "string"],
              "doc": "Customer is contractually obliged to pay invoices (Payment terms agreed by Customer and DT - net30, 60, etc)",
              "default": null
            },
            {
              "name": "industryTypeCode",
              "type": ["null", "string"],
              "doc": "Customer industry type",
              "default": null
            },
            {
              "name": "tireCertificateChargeCode",
              "type": ["null", "string"],
              "doc": "Code indicating if customer should be charged for certificates (01,02,Null - charge, do not charge, Null)",
              "default": null
            },
            {
              "name": "purchaseOrderRequiredIndicator",
              "type": ["boolean", "null"],
              "doc": "Flag to indicate whether Purchase Orders are required from customer",
              "default": false
            },
            {
              "name": "taxpayerIdentificationNumber",
              "type": ["null", "string"],
              "doc": "Tax ID number for organization type customer",
              "default": null
            },
            {
              "name": "postingBlockIndicator",
              "type": ["boolean", "null"],
              "doc": "Flag indicating that a customer's invoice documents are prevented from being posted on to Financial Accounting",
              "default": false
            },
            {
              "name": "fleetAccount",
              "type": {
                "type": "record",
                "name": "FleetAccount",
                "fields": [
                  {
                    "name": "fleetAgentFirstName",
                    "type": ["null", "string"],
                    "doc": "First name of DT Fleet Agent assigned to customer",
                    "default": null
                  },
                  {
                    "name": "fleetAgentLastName",
                    "type": ["null", "string"],
                    "doc": "Last name of DT Fleet Agent assigned to customer",
                    "default": null
                  },
                  {
                    "name": "fleetAgentPhoneNumber",
                    "type": ["null", "string"],
                    "doc": "Phone number of assigned fleet agend",
                    "default": null
                  }
                ]
              },
              "doc": "Contains attributes related to a business/organization where the relationship is managed by the Discount Tire Fleet group."
            }
          ]
        }
      ],
      "doc": "Contains attributes related to a Customer who is a business/organization, not an individual consumer.",
      "default": null
    },
    {
      "name": "personAttribute",
      "type": [
        "null",
        {
          "type": "record",
          "name": "CustomerPersonAttribute",
          "fields": [
            {
              "name": "firstName",
              "type": ["null", "string"],
              "doc": "Customer's first name",
              "default": null
            },
            {
              "name": "lastName",
              "type": ["null", "string"],
              "doc": "Customer's Last name",
              "default": null
            },
            {
              "name": "middleName",
              "type": ["null", "string"],
              "doc": "Middle name of party",
              "default": null
            },
            {
              "name": "fullName",
              "type": "string",
              "doc": "Full name of party RAW data. Contains first, middle, and last name concatenated with space delimiters where available"
            },
            {
              "name": "suffixName",
              "type": ["null", "string"],
              "doc": "Suffix name of the party",
              "default": null
            },
            {
              "name": "prefixName",
              "type": ["null", "string"],
              "doc": "Prefix for the name of the person",
              "default": null
            },
            {
              "name": "militaryIdentificationIndicator",
              "type": ["boolean", "null"],
              "doc": "Flag indicating if customer is active or retired military individual",
              "default": false
            }
          ]
        }
      ],
      "doc": "Contains attributes related to a Customer who is a business/organization, not an individual consumer.",
      "default": null
    },
    {
      "name": "addresses",
      "type": {
        "type": "array",
        "items": {
          "type": "record",
          "name": "CustomerAddress",
          "fields": [
            {
              "name": "customerAddressIdentifier",
              "type": "string",
              "doc": "Unique record ID generated by the system denoting the customer's primary address"
            },
            {
              "name": "addressTypeCode",
              "type": ["null", "string"],
              "doc": "Unique record ID generated by the system denoting whether the customer's given address is primary, secondary, mailing, etc.",
              "default": null
            },
            {
              "name": "addressTypeDescription",
              "type": ["null", "string"],
              "doc": "Text providing additional information about the address type",
              "default": null
            },
            {
              "name": "effectiveDate",
              "type": ["null", "string"],
              "doc": "Date customer's address is confirmed",
              "default": null
            },
            {
              "name": "expirationDate",
              "type": ["null", "string"],
              "doc": "Date customer's address is confirmed to have changed",
              "default": null
            },
            {
              "name": "defaultIndicator",
              "type": ["boolean", "null"],
              "doc": "Flag to indicate whether the address is the default address for a customer",
              "default": false
            },
            {
              "name": "addressLine1",
              "type": ["null", "string"],
              "doc": "Line 1 of the address value derived from Address Doctor",
              "default": null
            },
            {
              "name": "addressLine2",
              "type": ["null", "string"],
              "doc": "Line 2 of the address value derived from Address Doctor",
              "default": null
            },
            {
              "name": "stateCode",
              "type": ["null", "string"],
              "doc": "State where party is located, value from Address Doctor",
              "default": null
            },
            {
              "name": "cityName",
              "type": ["null", "string"],
              "doc": "City of the address derived from Address Doctor",
              "default": null
            },
            {
              "name": "countyName",
              "type": ["null", "string"],
              "doc": "County of the address derived from Address Doctor",
              "default": null
            },
            {
              "name": "postalCode",
              "type": ["null", "string"],
              "doc": "Postal Code where party is located, value from Address Doctor",
              "default": null
            },
            {
              "name": "extendedPostalCode",
              "type": ["null", "string"],
              "doc": "\"Postal code extension\" - 4 additional digits on Zip Code?",
              "default": null
            },
            {
              "name": "countryCode",
              "type": ["null", "string"],
              "doc": "Code representing the country of the customer address derived from Address Doctor",
              "default": null
            },
            {
              "name": "enrichmentIndicator",
              "type": ["boolean", "null"],
              "doc": "Flag indicating if data has been appended with data collected from additional source",
              "default": false
            }
          ]
        }
      },
      "doc": "Contains attributes related to a Customer who is a business/organization, not an individual consumer.",
      "default": []
    },
    {
      "name": "vehicles",
      "type": {
        "type": "array",
        "items": {
          "type": "record",
          "name": "CustomerVehicle",
          "fields": [
            {
              "name": "customerVehicleIdentifier",
              "type": "string",
              "doc": "Unique record ID generated by the system for the customer's specific vehicle"
            },
            {
              "name": "vehicleIdentifier",
              "type": "string",
              "doc": "Id generated by the system to describe generic vehicle matching that of the customer"
            },
            {
              "name": "trimIdentifier",
              "type": ["null", "string"],
              "doc": "Id generated by the system to denote the version of the customer's car's model",
              "default": null
            },
            {
              "name": "assemblyIdentifier",
              "type": ["null", "string"],
              "doc": "Unique record ID generated by the system indicating customer vehicle's assembly code",
              "default": null
            },
            {
              "name": "liftIdentifier",
              "type": ["null", "string"],
              "doc": "Unique code generated by the system to indicate lift package of vehicle",
              "default": null
            },
            {
              "name": "VIN",
              "type": ["null", "string"],
              "doc": "Vehicle Identification Number of a customer's vehicle",
              "default": null
            },
            {
              "name": "liscencePlateCountryCode",
              "type": ["null", "string"],
              "doc": "Country of the vehicle's license plate",
              "default": null
            },
            {
              "name": "liscencePlateStateCode",
              "type": ["null", "string"],
              "doc": "State of the vehicle's license plate",
              "default": null
            },
            {
              "name": "liscencePlateNumber",
              "type": ["null", "string"],
              "doc": "Alphanumeric code on the vehicle's license plate",
              "default": null
            },
            {
              "name": "alternateIdentifiers",
              "type": {
                "type": "array",
                "items": {
                  "type": "record",
                  "name": "VehicleAlternateIdentifier",
                  "fields": [
                    {
                      "name": "vehicleAlternateIdentifier",
                      "type": "string",
                      "doc": "Unique record ID generated by the system for ay alternate identifiers for a given vehicle"
                    },
                    {
                      "name": "sourceSystemName",
                      "type": "string",
                      "doc": "Name of system where relevant data is being sourced"
                    }
                  ]
                }
              },
              "doc": "It contains 1 to n vehicle alternate identifiers per customer, 1 entry per vehicle differentiated by the vehicle identifier",
              "default": []
            }
          ]
        }
      },
      "doc": "Contains attributes related to a Customer who is a business/organization, not an individual consumer.",
      "default": []
    },
    {
      "name": "contacts",
      "type": {
        "type": "array",
        "items": {
          "type": "record",
          "name": "CustomerContact",
          "fields": [
            {
              "name": "customerContactIdentifier",
              "type": "string",
              "doc": "Unique record Id generated by the system indicating customer's contact information"
            },
            {
              "name": "title",
              "type": ["null", "string"],
              "doc": "Title of customer",
              "default": null
            },
            {
              "name": "firstName",
              "type": ["null", "string"],
              "doc": "Customer's first name",
              "default": null
            },
            {
              "name": "lastName",
              "type": ["null", "string"],
              "doc": "Customer's Last name",
              "default": null
            },
            {
              "name": "phoneNumber",
              "type": ["null", "string"],
              "doc": "Customer's primary phone number",
              "default": null
            },
            {
              "name": "alternatePhoneNumber",
              "type": ["null", "string"],
              "doc": "Customer's secondary phone number",
              "default": null
            },
            {
              "name": "email",
              "type": ["null", "string"],
              "doc": "Customer's primary email",
              "default": null
            },
            {
              "name": "emailInvoiceRequiredIndicator",
              "type": ["null", "boolean"],
              "doc": "Flag inidicating whether customer should be sent email invoice of transaction",
              "default": null
            },
            {
              "name": "additionalContactIndicator",
              "type": ["null", "boolean"],
              "doc": "Flag inidcating if contact information belongs to a secondary contact",
              "default": null
            },
            {
              "name": "primaryContactIndicator",
              "type": ["null", "boolean"],
              "doc": "Flag inidcating if contact information belongs to primary contact",
              "default": null
            },
            {
              "name": "emails",
              "type": {
                "type": "array",
                "items": {
                  "type": "record",
                  "name": "CustomerContactEmail",
                  "fields": [
                    {
                      "name": "customerContactEmailIdentifier",
                      "type": "string",
                      "doc": "Unique record identifier for a customer's email"
                    },
                    {
                      "name": "email",
                      "type": ["null", "string"],
                      "doc": "Primary email address of customer",
                      "default": null
                    },
                    {
                      "name": "effectiveDate",
                      "type": ["null", "string"],
                      "doc": "Date the customer's email became valid",
                      "default": null
                    },
                    {
                      "name": "expirationDate",
                      "type": ["null", "string"],
                      "doc": "Date the customer's email address expires",
                      "default": null
                    },
                    {
                      "name": "defaultIndicator",
                      "type": ["null", "boolean"],
                      "doc": "Flag to inidicate if selected information for customer is default method of communication",
                      "default": null
                    },
                    {
                      "name": "contactEmailTypeCode",
                      "type": "string",
                      "doc": "Unique code generated to indicate type of email listed (work, personal)"
                    },
                    {
                      "name": "contactEmailTypeDescription",
                      "type": ["null", "string"],
                      "doc": "Text providing additional information about the email type",
                      "default": null
                    },
                    {
                      "name": "statusCode",
                      "type": ["null", "string"],
                      "doc": "Code indicating status of email address",
                      "default": null
                    },
                    {
                      "name": "usageTypeCode",
                      "type": ["null", "string"],
                      "doc": "Code indicating the type of usage for the email address",
                      "default": null
                    }
                  ]
                }
              },
              "doc": "The CustomerContactEmail namespace is a collection, each customer may have 0 to N Contact Emails",
              "default": []
            },
            {
              "name": "phones",
              "type": {
                "type": "array",
                "items": {
                  "type": "record",
                  "name": "CustomerContactPhone",
                  "fields": [
                    {
                      "name": "customerContactPhoneIdentifier",
                      "type": "string",
                      "doc": "Unique record identifier for a customer's phone number"
                    },
                    {
                      "name": "contactPhoneTypeCode",
                      "type": "string",
                      "doc": "Unique code inidicating type of phone number listed (work, cell, home)"
                    },
                    {
                      "name": "contactPhoneTypeDescription",
                      "type": ["null", "string"],
                      "doc": "Text providing additional information about the phone type",
                      "default": null
                    },
                    {
                      "name": "phoneNumber",
                      "type": ["null", "string"],
                      "doc": "Customer phone number",
                      "default": null
                    },
                    {
                      "name": "nationalCode",
                      "type": ["null", "string"],
                      "doc": "national/area code for customer's phone number",
                      "default": null
                    },
                    {
                      "name": "internationalCode",
                      "type": ["null", "string"],
                      "doc": "international code for customer's phone number",
                      "default": null
                    },
                    {
                      "name": "phoneExtensionNumber",
                      "type": ["null", "string"],
                      "doc": "phone extension number",
                      "default": null
                    },
                    {
                      "name": "defaultIndicator",
                      "type": ["null", "boolean"],
                      "doc": "flag indicating if this is the customer's default phone number",
                      "default": null
                    }
                  ]
                }
              },
              "doc": "The CustomerContactPhone namespace is a collection",
              "default": []
            },
            {
              "name": "characteristics",
              "type": {
                "type": "array",
                "items": {
                  "type": "record",
                  "name": "CustomerContactCharacteristic",
                  "fields": [
                    {
                      "name": "customerContactCharacteristicIdentifier",
                      "type": "string",
                      "doc": "Unique record Id generated by the system indicating customer's contact information"
                    },
                    {
                      "name": "customerContactDescription",
                      "type": ["null", "string"],
                      "doc": "Unique record Id generated by the system indicating customer's contact information",
                      "default": null
                    }
                  ]
                }
              },
              "doc": "The CustomerContactCharacteristics namespace is a collection",
              "default": []
            }
          ]
        }
      },
      "doc": "Contains attributes related to a Customer who is a business/organization, not an individual consumer.",
      "default": []
    },
    {
      "name": "alternateIdentifiers",
      "type": {
        "type": "array",
        "items": {
          "type": "record",
          "name": "CustomerAlternateIdentifier",
          "fields": [
            {
              "name": "customerAlternateIdentifier",
              "type": "string",
              "doc": "Unique record ID generated by the system for ay alternate identifiers for a given customer"
            },
            {
              "name": "sourceSystemName",
              "type": "string",
              "doc": "Name of system where relevant data is being sourced"
            }
          ]
        }
      },
      "doc": "Contains attributes related to a Customer who is a business/organization, not an individual consumer.",
      "default": []
    },
    {
      "name": "memberships",
      "type": {
        "type": "array",
        "items": {
          "type": "record",
          "name": "CustomerMembership",
          "fields": [
            {
              "name": "membershipTypeCode",
              "type": "string",
              "doc": "Code specifying the type of membership (AAA, etc.)"
            },
            {
              "name": "membershipTypeDescription",
              "type": ["null", "string"],
              "doc": "Brief description of details of AAA memberhsip",
              "default": null
            },
            {
              "name": "membershipIdentifier",
              "type": "string",
              "doc": "Membership Id value (AAA membership number, etc.)"
            }
          ]
        }
      },
      "doc": "Contains attributes related to a Customer who is a business/organization, not an individual consumer.",
      "default": []
    }
  ]
}
