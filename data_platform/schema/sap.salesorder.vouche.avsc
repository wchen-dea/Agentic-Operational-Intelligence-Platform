{
  "type": "record",
  "name": "vouche",
  "namespace": "com.canonicla.sap.salesorder",
  "fields": [
    {
      "name": "siteNumber",
      "type": "string",
      "doc": "Unique record Id generated by the system identifying a specific site"
    },
    {
      "name": "voucherNumber",
      "type": "string",
      "doc": "Unique record Id generated by the system identifying a voucher transaction"
    },
    {
      "name": "dayDate",
      "type": "string",
      "doc": "Date for the voucher transaction"
    },
    {
      "name": "voucherType",
      "type": "string",
      "doc": "Define type of voucher transaction (cash-in, cash-out, cash revenue, cash withdrawal for bank deposit)"
    },
    {
      "name": "voucherTypeDescription",
      "type": ["null", "string"],
      "doc": "Description of voucher type transaction (cash-in, cash-out, cash revenue, cash withdrawal for bank deposit)",
      "default": null
    },
    {
      "name": "voucherBagID",
      "type": ["null", "string"],
      "doc": "Identification used in the bag for Bank deposits",
      "default": null
    },
    {
      "name": "voucherAmount",
      "type": "float",
      "doc": "Voucher transaction amount in US Dollars"
    },
    {
      "name": "employeeIdentifier",
      "type": ["null", "string"],
      "doc": "Unique record identifier of the employee associated to the transaction record",
      "default": null
    },
    {
      "name": "voucherCategoryCode",
      "type": ["null", "string"],
      "doc": "Code representing the category of financial transaction that took place",
      "default": null
    },
    {
      "name": "voucherCategoryDescription",
      "type": ["null", "string"],
      "doc": "Description of the category of financial transaction that took place",
      "default": null
    },
    {
      "name": "voucherComments",
      "type": ["null", "string"],
      "doc": "Short description of item(s) purchased",
      "default": null
    },
    {
      "name": "rowKey",
      "type": "int",
      "doc": "Natural number"
    },
    {
      "name": "financialTransactionItemNumber",
      "type": "string",
      "doc": "Financial transaction item number"
    }
  ]
}
