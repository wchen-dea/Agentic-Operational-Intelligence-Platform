{
  "type": "record",
  "name": "employee",
  "namespace": "com.canonicla.kronos",
  "fields": [
    {
      "name": "employeeIdentifier",
      "type": "string",
      "doc": "Unique employee number generated by the system"
    },
    {
      "name": "firstName",
      "type": [
        "null",
        "string"
      ],
      "doc": "Employee legal first name",
      "default": null
    },
    {
      "name": "lastName",
      "type": [
        "null",
        "string"
      ],
      "doc": "Employee legal last name",
      "default": null
    },
    {
      "name": "fullName",
      "type": [
        "null",
        "string"
      ],
      "doc": "Employee full legal name",
      "default": null
    },
    {
      "name": "positionJobCode",
      "type": [
        "null",
        "string"
      ],
      "doc": "Code representing the employee's current job position within Discount Tire",
      "default": null
    },
    {
      "name": "positionName",
      "type": [
        "null",
        "string"
      ],
      "doc": "Name of the employee's current job position",
      "default": null
    },
    {
      "name": "managementLevelCode",
      "type": [
        "null",
        "string"
      ],
      "doc": "Code representing the employee's current management level relative to the Discount Tire management hierarchy",
      "default": null
    },
    {
      "name": "managementLevelDescription",
      "type": [
        "null",
        "string"
      ],
      "doc": "Corresponding description of the management level code",
      "default": null
    },
    {
      "name": "employmentStatusCode",
      "type": [
        "null",
        "string"
      ],
      "doc": "Code representing the individual's employment status with Discount Tire ('A' for active, 'T' for terminated, 'L' for leave)",
      "default": null
    },
    {
      "name": "employeeTypeName",
      "type": [
        "null",
        "string"
      ],
      "doc": "Describes the type of employee based on time committment ('Full Time' or 'Part Time')",
      "default": null
    },
    {
      "name": "storeCode",
      "type": [
        "null",
        "string"
      ],
      "doc": "Code representing the Discount Tire store where the employee is assigned",
      "default": null
    },
    {
      "name": "supervisorIdentifier",
      "type": [
        "null",
        "string"
      ],
      "doc": "Unique employee number of the individual's direct superior",
      "default": null
    },
    {
      "name": "supervisorName",
      "type": [
        "null",
        "string"
      ],
      "doc": "Name of the individual's direct superior",
      "default": null
    },
    {
      "name": "effectiveStartDate",
      "type": [
        "null",
        "string"
      ],
      "doc": "Date individual started working as a Discount Tire employee",
      "default": null
    },
    {
      "name": "effectiveTerminationDate",
      "type": [
        "null",
        "string"
      ],
      "doc": "Date individual is no longer a Discount Tire employee",
      "default": null
    },
    {
      "name": "originalHireDate",
      "type": [
        "null",
        "string"
      ],
      "doc": "Date individual was originally hired as a Discount Tire employee",
      "default": null
    },
    {
      "name": "mostRecentRehireDate",
      "type": [
        "null",
        "string"
      ],
      "doc": "Date individual was rehired as a Discount Tire employee",
      "default": null
    },
    {
      "name": "certifications",
      "type": {
        "type": "array",
        "items": {
          "type": "record",
          "name": "EmployeeCertification",
          "fields": [
            {
              "name": "programId",
              "type": [
                "null",
                "string"
              ],
              "doc": "Unique id of the specific learning program in which the employee is enrolled",
              "default": null
            },
            {
              "name": "completedIndicator",
              "type": [
                "null",
                "string"
              ],
              "doc": "Flag indicating if employee completed the learning program",
              "default": null
            },
            {
              "name": "programCompletionDate",
              "type": [
                "null",
                "string"
              ],
              "doc": "Date employee completed learning program",
              "default": null
            },
            {
              "name": "programNameRank",
              "type": [
                "null",
                "int"
              ],
              "doc": "Name rank of the learning program",
              "default": null
            },
            {
              "name": "programTypeName",
              "type": [
                "null",
                "string"
              ],
              "doc": "Name of the type of learning program",
              "default": null
            },
            {
              "name": "sourceSystemName",
              "type": [
                "null",
                "string"
              ],
              "doc": "Source system where the learning program was taken",
              "default": null
            }
          ]
        }
      },
      "doc": "Array of EmployeeCertification objects",
      "default": []
    }
  ]
}
